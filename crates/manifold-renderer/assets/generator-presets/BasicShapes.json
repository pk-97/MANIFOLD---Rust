{
  "version": 2,
  "name": "BasicShapes",
  "description": "Trigger-cycled 2D SDF shapes — Square / Diamond / Octagon, anti-aliased with a per-pixel finite-difference fwidth. The `fill` enum picks the cycling strategy: Solid (3 shapes × 8 rotations, always filled), Mixed (6 variants × 8 rotations, alternating fill/wireframe — original snap behaviour), or Wireframe (3 shapes × 8 rotations, always outlined). The `Clip Trigger` toggle gates the cycling (defaults OFF): ON drives shape + rotation snap from `trigger_count` and eases the rotation over the quarter beat following each trigger (BPM-coupled, trigger-elapsed). OFF freezes the shape at variant 0 with no rotation animation. Renamed from `BasicShapesSnap` — the snap feel is now opt-in via the toggle, matching the Plasma shape.\n\nDecomposed into a single curated `node.shape_2d` primitive (Plasma precedent for single-shader generators).",
  "presetMetadata": {
    "id": "BasicShapes",
    "displayName": "Basic Shapes",
    "category": "Procedural",
    "oscPrefix": "basicShapes",
    "legacyDiscriminant": 2,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "line",
        "name": "Line",
        "min": 0.0005,
        "max": 0.03,
        "defaultValue": 0.015,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F4",
        "oscSuffix": "line"
      },
      {
        "id": "scale",
        "name": "Scale",
        "min": 0.25,
        "max": 3.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "scale"
      },
      {
        "id": "fill",
        "name": "Fill",
        "min": 0.0,
        "max": 2.0,
        "defaultValue": 1.0,
        "wholeNumbers": true,
        "isToggle": false,
        "formatString": "F0",
        "oscSuffix": "fill",
        "valueLabels": ["Solid", "Mixed", "Wireframe"]
      },
      {
        "id": "clip_trigger",
        "name": "Clip Trigger",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": true,
        "formatString": "F0",
        "oscSuffix": "clipTrigger"
      }
    ],
    "bindings": [
      { "id": "line",  "label": "Line",  "defaultValue": 0.015,
        "target": { "kind": "handleNode", "handle": "shape", "param": "line" },
        "convert": { "type": "Float" } },
      { "id": "scale", "label": "Scale", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "shape", "param": "scale" },
        "convert": { "type": "Float" } },
      { "id": "fill",  "label": "Fill",  "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "shape", "param": "fill_mode" },
        "convert": { "type": "EnumRound" } },
      { "id": "clip_trigger", "label": "Clip Trigger", "defaultValue": 0.0,
        "target": { "kind": "handleNode", "handle": "shape", "param": "clip_trigger" },
        "convert": { "type": "BoolThreshold" } }
    ],
    "skipMode": { "kind": "never" }
  },
  "nodes": [
    { "id": 0, "typeId": "system.generator_input", "handle": "input" },
    { "id": 1, "typeId": "node.shape_2d", "handle": "shape" },
    { "id": 2, "typeId": "system.final_output", "handle": "final_output" }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "aspect",        "toNode": 1, "toPort": "aspect" },
    { "fromNode": 0, "fromPort": "trigger_count", "toNode": 1, "toPort": "trigger_count" },
    { "fromNode": 1, "fromPort": "out",           "toNode": 2, "toPort": "in" }
  ]
}
