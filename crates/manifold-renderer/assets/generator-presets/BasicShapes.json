{
  "version": 2,
  "name": "BasicShapes",
  "description": "Trigger-cycled 2D SDF shape selector: Square, Diamond, Octagon. The variant_cycle counts triggers modulo 3 or 6 (solid/mixed/wireframe modes) to drive three parallel subsystems: shape selection (variant mod 3), rotation sequencing (trigger count to 8 snap angles via table lookup), and fill mode (variant div 3 selects wireframe on/off). Rotation target is eased over a quarter-beat window on each trigger via rotation_eased. Clip Trigger toggle gates all three outputs (shape index, fill mode, rotation target) to zero when off, freezing the shape at Square-Solid with zero rotation. The three shape instances are muxed by shape_idx at the final output, rendering with shared line width and scale from sliders. Groups flatten at load to the ungrouped graph, preserving all nodeIds and bindings.",
  "presetMetadata": {
    "id": "BasicShapes",
    "displayName": "Basic Shapes",
    "category": "Procedural",
    "oscPrefix": "basicShapes",
    "legacyDiscriminant": 2,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "line",
        "name": "Line",
        "min": 0.0005,
        "max": 0.03,
        "defaultValue": 0.015,
        "wholeNumbers": false,
