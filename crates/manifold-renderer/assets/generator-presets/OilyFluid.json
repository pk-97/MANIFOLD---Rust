        "convert": { "type": "Float" } },
      { "id": "vel_damp", "label": "Velocity Damp", "defaultValue": 0.98,
        "target": { "kind": "handleNode", "handle": "vel_damp_gain", "param": "gain" },
        "convert": { "type": "Float" } },
      { "id": "curl", "label": "Curl", "defaultValue": 0.2,
        "target": { "kind": "handleNode", "handle": "curl_gain", "param": "gain" },
        "convert": { "type": "Float" } },
      { "id": "relief", "label": "Relief", "defaultValue": 0.5,
