{
  "version": 2,
  "name": "Oily Fluid",
  "description": "Oily Fluid — decomposed from the legacy `OilyFluidGenerator` Rust struct into the curated primitive library. Two state-store feedback loops (color, velocity) carry the simulation across frames. Each frame: (a) the velocity feedback gets H+V Gaussian blurred to form a smoothed gradient-search field; (b) the velocity step extracts per-channel curl forcing from |color|'s normalised gradients (rotated 90°) and self-advects the blurred velocity by the unblurred, then damps and adds the forcing; (c) the color step advects color by the new velocity, mixes in two channels of 3D simplex noise injection, then carries the result back to the color feedback. The render layer offers 5 modes (Oil Slick / Flow Field / Height Map / PBR / Lines) selected via `node.mux_texture` and graded by `node.color_grade`.\n\nKnown parity deltas vs legacy (documented per `DECOMPOSING_GENERATORS.md` §9): (1) ~2-frame state delay through `node.feedback` instead of legacy's same-frame ping-pong + swap — visually indistinguishable for the chaotic sim, (2) ColorRamp / ChannelMix stubs mean the Flow Field warm-sepia tint is omitted — recover via the outer-card Hue / Saturation, (3) atomic decomposition runs more dispatches than the legacy's fused passes — accept small fp16 drift in iterated state, system is bounded (decay < 1) so errors fade rather than amplify, (4) the optional cs_seed warmup is skipped — sim evolves from black instead of layered noise so the look takes a few seconds to build.",
  "presetMetadata": {
    "id": "OilyFluid",
    "displayName": "Oily Fluid",
    "category": "Generator",
    "oscPrefix": "oilyFluid",
    "legacyDiscriminant": 24,
    "available": true,
    "params": [
      { "id": "speed",     "name": "Speed",            "min": 0.1,   "max": 4.0,    "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "feedback",  "name": "Feedback",         "min": 0.95,  "max": 0.9999, "defaultValue": 0.998, "wholeNumbers": false, "isToggle": false, "formatString": "F4" },
      { "id": "noise",     "name": "Noise",            "min": 0.0,   "max": 0.02,   "defaultValue": 0.002, "wholeNumbers": false, "isToggle": false, "formatString": "F4" },
      { "id": "vel_damp",  "name": "Velocity Damp",    "min": 0.85,  "max": 0.999,  "defaultValue": 0.98,  "wholeNumbers": false, "isToggle": false, "formatString": "F3" },
      { "id": "curl",      "name": "Curl",             "min": 0.0,   "max": 1.0,    "defaultValue": 0.2,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "relief",    "name": "Relief",           "min": 0.05,  "max": 2.0,    "defaultValue": 0.5,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "chroma",    "name": "Chroma",           "min": 0.0,   "max": 8.0,    "defaultValue": 2.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "contrast",  "name": "Contrast",         "min": 0.5,   "max": 3.0,    "defaultValue": 1.4,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "hue",       "name": "Hue",              "min": 0.0,   "max": 1.0,    "defaultValue": 0.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "sat",       "name": "Saturation",       "min": 0.0,   "max": 2.0,    "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "bright",    "name": "Brightness",       "min": 0.0,   "max": 2.0,    "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "vel_disp",  "name": "Velocity Displace","min": 0.1,   "max": 10.0,   "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "col_disp",  "name": "Color Displace",   "min": 0.1,   "max": 10.0,   "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "mode",      "name": "Mode",             "min": 0.0,   "max": 4.0,    "defaultValue": 0.0,   "wholeNumbers": true,  "isToggle": false, "valueLabels": ["Oil Slick", "Flow Field", "Height Map", "PBR", "Lines"] }
    ],
    "bindings": [
      { "id": "feedback", "label": "Feedback", "defaultValue": 0.998,
