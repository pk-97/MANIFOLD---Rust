      { "id": "curl",      "name": "Curl",             "min": 0.0,   "max": 1.0,    "defaultValue": 0.2,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "relief",    "name": "Relief",           "min": 0.05,  "max": 2.0,    "defaultValue": 0.5,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "chroma",    "name": "Chroma",           "min": 0.0,   "max": 8.0,    "defaultValue": 2.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "contrast",  "name": "Contrast",         "min": 0.5,   "max": 3.0,    "defaultValue": 1.4,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "hue",       "name": "Hue",              "min": 0.0,   "max": 1.0,    "defaultValue": 0.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "sat",       "name": "Saturation",       "min": 0.0,   "max": 2.0,    "defaultValue": 1.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
