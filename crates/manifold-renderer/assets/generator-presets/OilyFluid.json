        "convert": { "type": "Float" } },
      { "id": "sat", "label": "Saturation", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "grade", "param": "saturation" },
        "convert": { "type": "Float" } },
      { "id": "bright", "label": "Brightness", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "grade", "param": "gain" },
        "convert": { "type": "Float" } },
      { "id": "vel_disp", "label": "Velocity Displace", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "vel_advect", "param": "dt" },
        "convert": { "type": "Float" } },
      { "id": "col_disp", "label": "Color Displace", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "color_advect", "param": "dt" },
        "convert": { "type": "Float" } },
      { "id": "mode", "label": "Mode", "defaultValue": 0.0,
        "target": { "kind": "handleNode", "handle": "mode_mux", "param": "selector" },
        "convert": { "type": "EnumRound" } }
    ],
    "skipMode": { "kind": "never" }
  },
