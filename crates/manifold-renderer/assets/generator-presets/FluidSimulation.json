    { "id": 80, "typeId": "node.wgsl_compute", "handle": "seed_pattern",
      "wgslSource": "// FluidSim2D seed pattern — open family.\n// Writes a single-channel density Texture2D selecting one of 7\n// curated geometric patterns (or extend by appending a `case` to\n// the switch). The downstream `seed_particles_from_texture`\n// rejection-samples this density to place particles where it is\n// bright (R > 0.1).\n//\n// Patterns:\n//   0 — Center cluster (Gaussian)\n//   1 — Horizontal lines (6 lines)\n//   2 — Vertical lines (6 lines)\n//   3 — Concentric rings (3 rings)\n//   4 — Diagonal cross\n//   5 — Archimedean spiral\n//   6 — Edge ring\n\nstruct U {\n    pattern: u32,\n    _pad0: u32,\n    _pad1: u32,\n    _pad2: u32,\n};\n\n@group(0) @binding(0) var<uniform> u: U;\n@group(0) @binding(1) var output_tex: texture_storage_2d<r32float, write>;\n\nconst PI: f32 = 3.14159265;\nconst TAU: f32 = 6.28318530718;\n\nfn line_gauss(d: f32, thickness: f32) -> f32 {\n    return exp(-(d * d) / (2.0 * thickness * thickness));\n}\n\n@compute @workgroup_size(16, 16)\nfn cs_main(@builtin(global_invocation_id) id: vec3<u32>) {\n    let dims = textureDimensions(output_tex);\n    if id.x >= dims.x || id.y >= dims.y { return; }\n    let uv = (vec2<f32>(id.xy) + 0.5) / vec2<f32>(dims);\n    let delta = uv - vec2<f32>(0.5, 0.5);\n    let dist = length(delta);\n\n    var d: f32 = 0.0;\n\n    switch u.pattern {\n        case 0u: {\n            // Center cluster — Gaussian, sigma ~0.052 (matches legacy spread)\n            d = exp(-(dist * dist) / (2.0 * 0.052 * 0.052));\n        }\n        case 1u: {\n            // Horizontal lines (6 lines), Gaussian thickness 0.012\n            var best: f32 = 0.0;\n            for (var i = 0; i < 6; i++) {\n                let line_y = (f32(i) + 0.5) / 6.0;\n                best = max(best, line_gauss(uv.y - line_y, 0.012));\n            }\n            d = best;\n        }\n        case 2u: {\n            // Vertical lines (6 lines)\n            var best: f32 = 0.0;\n            for (var i = 0; i < 6; i++) {\n                let line_x = (f32(i) + 0.5) / 6.0;\n                best = max(best, line_gauss(uv.x - line_x, 0.012));\n            }\n            d = best;\n        }\n        case 3u: {\n            // Concentric rings (3 rings) at radii 0.1, 0.2, 0.3\n            var best: f32 = 0.0;\n            for (var i = 0; i < 3; i++) {\n                let r = 0.1 + f32(i) * 0.1;\n                best = max(best, line_gauss(dist - r, 0.01));\n            }\n            d = best;\n        }\n        case 4u: {\n            // Diagonal cross (X-shape)\n            let d1 = abs(uv.x - uv.y);\n            let d2 = abs(uv.x + uv.y - 1.0);\n            d = max(line_gauss(d1, 0.015), line_gauss(d2, 0.015));\n        }\n        case 5u: {\n            // Archimedean spiral — 4 turns, max radius 0.4.\n            // For each pixel, find the closest spiral radius for any\n            // angle wrap, accept if dist is near it.\n            let angle_norm = (atan2(delta.y, delta.x) + PI) / TAU; // [0, 1]\n            var best: f32 = 0.0;\n            for (var turn = 0; turn < 4; turn++) {\n                let theta_norm = angle_norm + f32(turn);\n                let spiral_r = (theta_norm / 4.0) * 0.4;\n                if spiral_r > 0.0 && spiral_r < 0.42 {\n                    best = max(best, line_gauss(dist - spiral_r, 0.012));\n                }\n            }\n            d = best;\n        }\n        case 6u: {\n            // Edge ring at radius 0.45\n            d = line_gauss(dist - 0.45, 0.012);\n        }\n        default: {\n            d = 0.0;\n        }\n    }\n\n    textureStore(output_tex, vec2<i32>(id.xy), vec4<f32>(d, 0.0, 0.0, 1.0));\n}\n",
      "params": { "pattern": { "type": "Float", "value": 3.0 } } },

