      { "id": "mode_x", "name": "Mode X", "min": 1.0, "max": 12.0, "defaultValue": 3.0, "wholeNumbers": true, "isToggle": false, "isTrigger": false, "formatString": "F0", "oscSuffix": "modeX" },
      { "id": "mode_y", "name": "Mode Y", "min": 1.0, "max": 12.0, "defaultValue": 2.0, "wholeNumbers": true, "isToggle": false, "isTrigger": false, "formatString": "F0", "oscSuffix": "modeY" },
      { "id": "symmetry", "name": "Symmetry", "min": 0.0, "max": 1.0, "defaultValue": 0.0, "wholeNumbers": true, "isToggle": true, "isTrigger": false, "formatString": "F0", "oscSuffix": "symmetry" },
