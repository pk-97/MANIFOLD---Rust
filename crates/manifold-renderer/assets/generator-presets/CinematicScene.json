{
  "version": 2,
  "name": "CinematicScene",
  "description": "Physical-camera 3D scene with true depth of field and contact-shadow AO (docs/CINEMATIC_POST_DESIGN.md D6). A faceted mesh under one key light, shot through node.camera_lens (the one lens node.render_scene's exposure AND node.coc_from_depth's circle-of-confusion both read), an ssao_from_depth -> node.mix(Multiply) contact-occlusion arm, and a coc_from_depth -> variable_blur(H) -> variable_blur(V) gather. Grown incrementally across CINEMATIC_POST's phases: P1 shipped the DoF chain; P2 adds the SSAO arm; P3 adds a motion-blur tail.",
  "presetMetadata": {
    "id": "CinematicScene",
    "displayName": "Cinematic Scene",
    "category": "Geometry",
    "oscPrefix": "cinematicScene",
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "focus_distance",
        "name": "Focus Distance",
        "min": 0.1,
        "max": 20.0,
        "defaultValue": 4.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "f_stop",
        "name": "F-Stop",
        "min": 0.5,
        "max": 32.0,
        "defaultValue": 2.8,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F1"
      },
      {
        "id": "exposure_ev",
        "name": "Exposure (EV)",
        "min": -8.0,
        "max": 8.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "ssao_intensity",
        "name": "SSAO Intensity",
        "min": 0.0,
        "max": 4.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "ssao_radius",
        "name": "SSAO Radius",
        "min": 0.01,
        "max": 5.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "focus_distance",
        "label": "Focus Distance",
        "defaultValue": 4.0,
        "target": {
          "kind": "node",
          "nodeId": "lens",
          "param": "focus_distance"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "f_stop",
        "label": "F-Stop",
        "defaultValue": 2.8,
        "target": {
          "kind": "node",
          "nodeId": "lens",
          "param": "f_stop"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "exposure_ev",
        "label": "Exposure (EV)",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "lens",
          "param": "exposure_ev"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "ssao_intensity",
        "label": "SSAO Intensity",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "ssao",
          "param": "intensity"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "ssao_radius",
        "label": "SSAO Radius",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "ssao",
          "param": "radius"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "never"
    }
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.generator_input",
      "nodeId": "input",
      "handle": "input"
    },
    {
      "id": 1,
      "typeId": "node.grid_mesh",
      "nodeId": "grid",
      "handle": "grid",
      "title": "Grid",
      "params": {
        "max_capacity": { "type": "Int", "value": 2000 },
        "resolution_x": { "type": "Int", "value": 40 },
        "resolution_y": { "type": "Int", "value": 40 },
        "size_x": { "type": "Float", "value": 2.0 },
        "size_y": { "type": "Float", "value": 2.0 }
      }
    },
    {
      "id": 2,
      "typeId": "node.make_triangles",
      "nodeId": "tris",
      "handle": "tris",
      "title": "Triangulate",
      "params": {
        "src_cols": { "type": "Int", "value": 40 },
        "src_rows": { "type": "Int", "value": 40 }
      }
    },
    {
      "id": 3,
      "typeId": "node.facet_normals",
      "nodeId": "facets",
      "handle": "facets",
      "title": "Facet Normals"
    },
    {
      "id": 4,
      "typeId": "node.orbit_camera",
      "nodeId": "cam",
      "handle": "cam",
      "title": "Camera",
      "params": {
        "orbit": { "type": "Float", "value": 0.6 },
        "tilt": { "type": "Float", "value": 0.6 },
        "distance": { "type": "Float", "value": 4.0 },
        "fov_y": { "type": "Float", "value": 0.8 }
      }
    },
    {
      "id": 5,
      "typeId": "node.camera_lens",
      "nodeId": "lens",
      "handle": "lens",
      "title": "Lens",
      "params": {
        "focus_distance": { "type": "Float", "value": 4.0 },
        "f_stop": { "type": "Float", "value": 2.8 },
        "shutter_angle": { "type": "Float", "value": 0.0 },
        "exposure_ev": { "type": "Float", "value": 0.0 }
      }
    },
    {
      "id": 6,
      "typeId": "node.phong_material",
      "nodeId": "mat",
      "handle": "mat",
      "title": "Material",
      "params": {
        "color_r": { "type": "Float", "value": 1.0 },
        "color_g": { "type": "Float", "value": 0.85 },
        "color_b": { "type": "Float", "value": 0.6 },
        "ambient": { "type": "Float", "value": 0.1 }
      }
    },
    {
      "id": 7,
      "typeId": "node.light",
      "nodeId": "key_light",
      "handle": "key_light",
      "title": "Key Light",
      "params": {
        "mode": { "type": "Enum", "value": 0 },
        "pos_x": { "type": "Float", "value": 0.0 },
        "pos_y": { "type": "Float", "value": 30.0 },
        "pos_z": { "type": "Float", "value": 0.0 },
        "aim_x": { "type": "Float", "value": 0.0 },
        "aim_y": { "type": "Float", "value": 0.0 },
        "aim_z": { "type": "Float", "value": 0.0 },
        "color_r": { "type": "Float", "value": 1.0 },
        "color_g": { "type": "Float", "value": 1.0 },
        "color_b": { "type": "Float", "value": 1.0 },
        "intensity": { "type": "Float", "value": 1.0 },
        "cast_shadows": { "type": "Float", "value": 0.0 }
      }
    },
    {
      "id": 8,
      "typeId": "node.render_scene",
      "nodeId": "scene",
      "handle": "scene",
      "title": "Render Scene",
      "params": {
        "objects": { "type": "Int", "value": 1 },
        "lights": { "type": "Int", "value": 1 }
      }
    },
    {
      "id": 12,
      "typeId": "node.ssao_from_depth",
      "nodeId": "ssao",
      "handle": "ssao",
      "title": "SSAO From Depth",
      "params": {
        "radius": { "type": "Float", "value": 0.5 },
        "intensity": { "type": "Float", "value": 1.0 },
        "bias": { "type": "Float", "value": 0.025 }
      }
    },
    {
      "id": 13,
      "typeId": "node.mix",
      "nodeId": "ssao_mix",
      "handle": "ssao_mix",
      "title": "SSAO Multiply",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 4 }
      }
    },
    {
      "id": 9,
      "typeId": "node.coc_from_depth",
      "nodeId": "coc",
      "handle": "coc",
      "title": "CoC From Depth",
      "params": {
        "max_radius": { "type": "Float", "value": 24.0 }
      }
    },
    {
      "id": 10,
      "typeId": "node.variable_blur",
      "nodeId": "blur_h",
      "handle": "blur_h",
      "title": "DoF Blur H",
      "params": {
        "axis": { "type": "Enum", "value": 0 },
        "max_radius": { "type": "Float", "value": 24.0 },
        "quality": { "type": "Enum", "value": 1 },
        "weighting_mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 11,
      "typeId": "node.variable_blur",
      "nodeId": "blur_v",
      "handle": "blur_v",
      "title": "DoF Blur V",
      "params": {
        "axis": { "type": "Enum", "value": 1 },
        "max_radius": { "type": "Float", "value": 24.0 },
        "quality": { "type": "Enum", "value": 1 },
        "weighting_mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 99,
      "typeId": "system.final_output",
      "nodeId": "out",
      "handle": "out"
    }
  ],
  "wires": [
    { "fromNode": 1, "fromPort": "vertices", "toNode": 2, "toPort": "in" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "camera" },
    { "fromNode": 5, "fromPort": "out", "toNode": 8, "toPort": "camera" },
    { "fromNode": 5, "fromPort": "out", "toNode": 9, "toPort": "camera" },
    { "fromNode": 5, "fromPort": "out", "toNode": 12, "toPort": "camera" },
    { "fromNode": 6, "fromPort": "out", "toNode": 8, "toPort": "material_0" },
    { "fromNode": 7, "fromPort": "out", "toNode": 8, "toPort": "light_0" },
    { "fromNode": 3, "fromPort": "out", "toNode": 8, "toPort": "mesh_0" },
    { "fromNode": 8, "fromPort": "depth", "toNode": 9, "toPort": "depth" },
    { "fromNode": 8, "fromPort": "depth", "toNode": 12, "toPort": "depth" },
    { "fromNode": 8, "fromPort": "color", "toNode": 13, "toPort": "a" },
    { "fromNode": 12, "fromPort": "out", "toNode": 13, "toPort": "b" },
    { "fromNode": 13, "fromPort": "out", "toNode": 10, "toPort": "in" },
    { "fromNode": 9, "fromPort": "out", "toNode": 10, "toPort": "width" },
    { "fromNode": 10, "fromPort": "out", "toNode": 11, "toPort": "in" },
    { "fromNode": 9, "fromPort": "out", "toNode": 11, "toPort": "width" },
    { "fromNode": 11, "fromPort": "out", "toNode": 99, "toPort": "in" }
  ]
}
