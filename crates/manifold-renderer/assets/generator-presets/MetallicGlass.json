      { "id": "cam_tilt",    "label": "Camera Tilt",     "defaultValue": -10.0,
        "target": { "kind": "handleNode", "handle": "cam_tilt_deg_to_rad", "param": "a" },
        "convert": { "type": "Float" } },

      { "id": "cam_fov",     "label": "Camera FOV",      "defaultValue": 54.0,
