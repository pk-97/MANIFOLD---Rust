      { "id": "feather",           "name": "Feather",           "min": 4.0,   "max": 60.0,   "defaultValue": 20.0,   "wholeNumbers": true,  "isToggle": false, "formatString": "F0" },
      { "id": "curl",              "name": "Curl",              "min": 30.0,  "max": 90.0,   "defaultValue": 85.0,   "wholeNumbers": false, "isToggle": false, "formatString": "F0" },
      { "id": "turbulence",        "name": "Turbulence",        "min": 0.0,   "max": 0.01,   "defaultValue": 0.001,  "wholeNumbers": false, "isToggle": false, "formatString": "F4" },
      { "id": "speed",             "name": "Speed",             "min": 0.1,   "max": 3.0,    "defaultValue": 1.0,    "wholeNumbers": false, "isToggle": false, "formatString": "F1" },
      { "id": "contrast",          "name": "Contrast",          "min": 1.0,   "max": 8.0,    "defaultValue": 3.5,    "wholeNumbers": false, "isToggle": false, "formatString": "F1" },
      { "id": "scale",             "name": "Scale",             "min": 0.25,  "max": 3.0,    "defaultValue": 1.0,    "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "count_m",           "name": "Particle Count",    "min": 0.1,   "max": 8.0,    "defaultValue": 2.0,    "wholeNumbers": false, "isToggle": false, "formatString": "F1" },
      { "id": "clip_trigger",      "name": "Clip Trigger",      "min": 0.0,   "max": 1.0,    "defaultValue": 0.0,    "wholeNumbers": true,  "isToggle": true,  "formatString": "F0" },
      { "id": "clip_trigger_mode", "name": "Clip Trigger Mode", "min": 0.0,   "max": 4.0,    "defaultValue": 0.0,    "wholeNumbers": true,  "isToggle": false, "valueLabels": ["Turbulence", "Rot Flip", "Flow Inv", "Pattern", "Inject"] },
      { "id": "size",              "name": "Size",              "min": 1.0,   "max": 8.0,    "defaultValue": 3.0,    "wholeNumbers": false, "isToggle": false, "formatString": "F1" },
