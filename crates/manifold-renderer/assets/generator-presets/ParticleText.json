    { "id": 80, "typeId": "node.wgsl_compute", "handle": "seed_pattern",
      "wgslSource": "// FluidSim2D seed pattern — open family.\n// Writes particle positions directly into the aliased Array<Particle>\n// based on `pattern` (0-6). Bit-equivalent to the legacy fluid_seed.wgsl.\n// Adding an 8th pattern: append a `case` to the switch.\n//\n// Patterns (legacy):\n//   0 — CLT Gaussian center cluster (spread 0.052)\n//   1 — Horizontal lines (6 lines)\n//   2 — Vertical lines (6 lines)\n//   3 — Concentric rings (3 rings, radii 0.1/0.2/0.3)\n//   4 — Diagonal cross\n//   5 — Archimedean spiral (4 turns, max r=0.4)\n//   6 — Edge ring (r=0.45)\n//\n// For i >= active_count: held dead at the centre nozzle (life=0).\n// The downstream array_feedback copies this seed buffer into its\n// state.prev on first allocation and on reset_trigger edge.\n\nstruct Particle {\n    position: vec3<f32>,\n    velocity: vec3<f32>,\n    life: f32,\n    age: f32,\n    color: vec4<f32>,\n};\n\nstruct U {\n    pattern: u32,\n    trigger_count: u32,\n    active_count: u32,\n    _pad0: u32,\n};\n\n@group(0) @binding(0) var<uniform> u: U;\n@group(0) @binding(1) var<storage, read_write> particles: array<Particle>;\n\nconst TAU: f32 = 6.28318530718;\n\nfn wang_hash(seed_in: u32) -> u32 {\n    var seed = seed_in;\n    seed = (seed ^ 61u) ^ (seed >> 16u);\n    seed = seed * 9u;\n    seed = seed ^ (seed >> 4u);\n    seed = seed * 0x27d4eb2du;\n    seed = seed ^ (seed >> 15u);\n    return seed;\n}\n\nfn hash_float(seed: u32) -> f32 {\n    return f32(wang_hash(seed)) / 4294967296.0;\n}\n\nfn hash_float2(seed: u32) -> vec2<f32> {\n    let h1 = wang_hash(seed);\n    let h2 = wang_hash(h1);\n    return vec2<f32>(f32(h1), f32(h2)) / 4294967296.0;\n}\n\n@compute @workgroup_size(256, 1, 1)\nfn cs_main(@builtin(global_invocation_id) id: vec3<u32>) {\n    let i = id.x;\n    if i >= arrayLength(&particles) {\n        return;\n    }\n\n    var p: Particle;\n    p.velocity = vec3<f32>(0.0);\n    p.age = -1.0;\n    p.color = vec4<f32>(0.005, 0.005, 0.005, 1.0);\n\n    // Excess particles: held dead at the centre nozzle, slight\n    // random radial scatter so they don't all sit on one pixel.\n    if i >= u.active_count {\n        let spread_hash_a = f32(wang_hash(i * 1664525u + 12345u)) / 4294967296.0;\n        let spread_hash_b = f32(wang_hash(wang_hash(i * 1664525u + 12345u))) / 4294967296.0;\n        let spread_r = spread_hash_a * 0.05;\n        let spread_a = spread_hash_b * 6.28318;\n        p.position = vec3<f32>(\n            0.5 + cos(spread_a) * spread_r,\n            0.5 + sin(spread_a) * spread_r,\n            0.0,\n        );\n        p.life = 0.0;\n        particles[i] = p;\n        return;\n    }\n\n    let seed = i * 1664525u + u.trigger_count * 747796405u;\n    var x: f32;\n    var y: f32;\n\n    switch u.pattern {\n        case 0u: {\n            // CLT Gaussian centre cluster — sum of 4 uniform hashes.\n            var sx = 0.0;\n            var sy = 0.0;\n            var s = seed;\n            for (var j = 0; j < 4; j++) {\n                let h = hash_float2(s);\n                sx += h.x;\n                sy += h.y;\n                s = wang_hash(s);\n            }\n            x = 0.5 + (sx - 2.0) * 0.052;\n            y = 0.5 + (sy - 2.0) * 0.052;\n        }\n        case 1u: {\n            let line_idx = i % 6u;\n            x = hash_float(seed);\n            y = (f32(line_idx) + 0.5) / 6.0;\n        }\n        case 2u: {\n            let line_idx = i % 6u;\n            x = (f32(line_idx) + 0.5) / 6.0;\n            y = hash_float(seed);\n        }\n        case 3u: {\n            let ring_idx = i % 3u;\n            let angle = hash_float(seed) * TAU;\n            let radius = 0.1 + f32(ring_idx) * 0.1;\n            x = 0.5 + cos(angle) * radius;\n            y = 0.5 + sin(angle) * radius;\n        }\n        case 4u: {\n            let t = hash_float(seed);\n            let spread = hash_float(seed + 1u) * 0.03;\n            if (i & 1u) != 0u {\n                x = t + spread;\n                y = t - spread;\n            } else {\n                x = t + spread;\n                y = (1.0 - t) - spread;\n            }\n        }\n        case 5u: {\n            let norm = f32(i) / f32(u.active_count);\n            let angle = norm * 4.0 * TAU;\n            let radius = norm * 0.4;\n            let spread = hash_float(seed) * 0.015;\n            x = 0.5 + cos(angle) * (radius + spread);\n            y = 0.5 + sin(angle) * (radius + spread);\n        }\n        case 6u: {\n            let angle = hash_float(seed) * TAU;\n            let spread = (hash_float(seed + 1u) - 0.5) * 0.03;\n            x = 0.5 + cos(angle) * (0.45 + spread);\n            y = 0.5 + sin(angle) * (0.45 + spread);\n        }\n        default: {\n            let pos = hash_float2(seed);\n            x = pos.x;\n            y = pos.y;\n        }\n    }\n\n    p.position = vec3<f32>(fract(x + 1.0), fract(y + 1.0), 0.0);\n    p.life = 1.0;\n    particles[i] = p;\n}\n",
      "params": {
        "pattern":       { "type": "Float", "value": 3.0 },
        "trigger_count": { "type": "Float", "value": 42.0 },
        "active_count":  { "type": "Float", "value": 2000000.0 }
      } },

