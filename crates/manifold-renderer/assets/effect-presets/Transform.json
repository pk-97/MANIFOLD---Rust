{
  "version": 2,
  "name": "Transform",
  "description": "A canonical spatial effect that applies affine transformation to the input: translation (X, Y), scale (Zoom), and rotation. The transformation matrix is computed from four independent card bindings, applied to the source material, and passed to output. This is the default transform effect in the patch library.",
  "presetMetadata": {
    "id": "Transform",
    "displayName": "Transform",
    "category": "Spatial",
    "oscPrefix": "transform",
    "legacyDiscriminant": 0,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "x",
        "name": "X",
        "min": -1.0,
        "max": 1.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "y",
        "name": "Y",
        "min": -1.0,
        "max": 1.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "zoom",
        "name": "Zoom",
        "min": 0.1,
        "max": 5.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "rotation",
        "name": "Rotation",
        "min": -180.0,
        "max": 180.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "wraps": true,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "x",
        "label": "X",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "transform",
          "param": "translate_x"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "y",
        "label": "Y",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "transform",
          "param": "translate_y"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "zoom",
        "label": "Zoom",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "transform",
          "param": "scale"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "rotation",
        "label": "Rotation",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "transform",
          "param": "rotation"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "never"
    },
    "paramAliases": [
      {
        "old": "rot",
        "new": "rotation"
      }
    ]
  },
  "nodes": [
    {
      "id": 0,
      "nodeId": "source",
      "typeId": "system.source",
      "handle": "source"
    },
    {
      "id": 1,
      "nodeId": "transform",
      "typeId": "node.transform",
      "handle": "transform",
      "params": {
        "rotation": {
          "type": "Float",
          "value": 0.0
        },
        "scale": {
          "type": "Float",
          "value": 1.0
        },
        "translate_x": {
          "type": "Float",
          "value": 0.0
        },
        "translate_y": {
          "type": "Float",
          "value": 0.0
        }
      },
      "title": "Affine Transform"
    },
    {
      "id": 2,
      "nodeId": "final_output",
      "typeId": "system.final_output",
      "handle": "final_output"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "in"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "in"
    }
  ]
}
