{
  "version": 2,
  "name": "ColorCompass",
  "description": "Image slides toward its own brightest direction. Four ColorSamples read N/E/S/W luma, subtractions produce a (dx, dy) direction vector, smoothing tames per-frame jitter, the smoothed components drive AffineTransform's translate_x / translate_y. Translation is proportional to brightness asymmetry — small asymmetry slides a little, big asymmetry slides a lot, and zero asymmetry is exactly zero (no atan2 degeneracy). Feedback-free; the loop closes through the one-frame texture→scalar bridge.",
  "presetMetadata": {
    "id": "ColorCompass",
    "displayName": "Color Compass",
    "category": "Spatial",
    "oscPrefix": "color_compass",
    "available": true,
    "params": [
      {
        "id": "intensity",
        "name": "Intensity",
        "min": 0.0,
        "max": 20.0,
        "defaultValue": 5.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "reactivity",
        "name": "Reactivity",
        "min": 0.01,
        "max": 2.0,
        "defaultValue": 0.05,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "intensity",
        "label": "Intensity",
        "defaultValue": 5.0,
        "target": {
          "kind": "handleNode",
          "handle": "intensity_value",
          "param": "value"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "reactivity",
        "label": "Reactivity",
        "defaultValue": 0.05,
        "target": {
          "kind": "handleNode",
          "handle": "reactivity_value",
          "param": "value"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "intensity"
    }
  },
  "nodes": [
