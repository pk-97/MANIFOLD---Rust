{
  "version": 2,
  "name": "BlobTracking",
  "description": "Decomposed Blob Track: FFI detection → NN identity tracking → 1€ temporal smoothing → composed HUD overlay built from the native Draw atoms (Draw Markers ×2, Draw Dots, Draw Gauge, Draw Ticks, Draw Connections, two value labels, Draw Scanlines). Every layer is an ordinary node — restyle it with params or swap it out in the graph editor. The whole HUD stack skips to a zero-cost passthrough while no blobs are detected.",
  "presetMetadata": {
    "id": "BlobTracking",
    "displayName": "Blob Track",
    "category": "Diagnostic",
    "oscPrefix": "blobTracking",
    "legacyDiscriminant": 22,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "threshold",
        "name": "Threshold",
        "min": 0.05,
        "max": 0.9,
        "defaultValue": 0.65,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Threshold"
      },
      {
        "id": "sensitivity",
        "name": "Sensitivity",
        "min": 0.2,
        "max": 1.0,
        "defaultValue": 0.85,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Sensitivity"
      },
      {
        "id": "smoothing",
        "name": "Smoothing",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.7,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Smoothing"
      },
      {
        "id": "connect",
        "name": "Connect",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.35,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Connect"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": { "kind": "node", "nodeId": "amount_value", "param": "a" },
        "convert": { "type": "Float" }
      },
      {
        "id": "threshold",
        "label": "Threshold",
        "defaultValue": 0.65,
        "target": { "kind": "node", "nodeId": "detect", "param": "threshold" },
        "convert": { "type": "Float" }
      },
      {
        "id": "sensitivity",
        "label": "Sensitivity",
        "defaultValue": 0.85,
        "target": { "kind": "node", "nodeId": "detect", "param": "sensitivity" },
        "convert": { "type": "Float" }
      },
      {
        "id": "smoothing",
        "label": "Smoothing",
        "defaultValue": 0.7,
        "target": { "kind": "node", "nodeId": "smoothing_remap", "param": "a" },
        "convert": { "type": "Float" }
      },
      {
        "id": "connect",
        "label": "Connect",
        "defaultValue": 0.35,
        "target": { "kind": "node", "nodeId": "connect_nearest", "param": "max_distance" },
        "convert": { "type": "Float" }
      }
    ],
    "skipMode": { "kind": "never" },
    "paramAliases": [
      { "old": "thresh", "new": "threshold" },
      { "old": "sens", "new": "sensitivity" },
      { "old": "smooth", "new": "smoothing" }
    ]
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source", "nodeId": "source" },
    {
      "id": 1,
      "typeId": "node.blob_detect_ffi",
      "handle": "detect", "nodeId": "detect",
      "params": {
        "threshold": { "type": "Float", "value": 0.65 },
        "sensitivity": { "type": "Float", "value": 0.85 },
        "max_capacity": { "type": "Float", "value": 8.0 },
        "analysis_max_dim": { "type": "Float", "value": 320.0 },
        "update_interval": { "type": "Float", "value": 3.0 }
      }
    },
    {
      "id": 2,
      "typeId": "node.track_persist",
      "handle": "tracker", "nodeId": "tracker",
      "params": {
        "match_radius": { "type": "Float", "value": 0.283 },
        "grace_frames": { "type": "Float", "value": 3.0 }
      }
    },
    {
      "id": 3,
      "typeId": "node.affine_scalar",
      "handle": "smoothing_remap", "nodeId": "smoothing_remap",
      "params": {
        "a": { "type": "Float", "value": 0.7 },
        "scale": { "type": "Float", "value": -3.7 },
        "offset": { "type": "Float", "value": 4.0 }
      }
    },
    {
      "id": 4,
      "typeId": "node.one_euro_filter",
      "handle": "smoother", "nodeId": "smoother",
      "params": {
