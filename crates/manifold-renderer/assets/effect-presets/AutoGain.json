{
  "version": 2,
  "name": "AutoGain",
  "description": "Tranche 7 decomposition. Visual dynamics compressor: node.luminance sparse-samples the source brightness; node.compressor_envelope runs a log-domain program-dependent attack/release envelope and emits a gain scalar; node.gain multiplies the source by that gain; node.wet_dry crossfades back over the dry source for parallel-compression amount. The original AutoGain's character / colour / HDR retention coloration moved to dedicated colour-treatment effects; this preset is now a pure level-rider utility.",
  "presetMetadata": {
    "id": "AutoGain",
    "displayName": "Auto Gain",
    "category": "Stylize",
    "oscPrefix": "autoGain",
    "legacyDiscriminant": 41,
    "available": true,
    "params": [
      { "id": "amount", "name": "Amount", "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "ratio",  "name": "Ratio",  "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "Ratio" },
      { "id": "punch",  "name": "Punch",  "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "Punch" },
      { "id": "target", "name": "Target", "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "Target" }
    ],
    "bindings": [
      { "id": "amount", "label": "Amount", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "wet_dry", "param": "wet_dry" },
        "convert": { "type": "Float" } },
      { "id": "ratio", "label": "Ratio", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "env", "param": "ratio" },
        "convert": { "type": "Float" } },
      { "id": "punch", "label": "Punch", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "env", "param": "punch" },
        "convert": { "type": "Float" } },
      { "id": "target", "label": "Target", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "env", "param": "target" },
        "convert": { "type": "Float" } }
    ],
    "skipMode": { "kind": "never" }
  },
  "nodes": [
    { "id": 0,  "typeId": "system.source",       "handle": "source" },
    { "id": 99, "typeId": "system.final_output", "handle": "final_output" },

    { "id": 10, "typeId": "node.luminance", "handle": "luminance" },

    {
      "id": 20, "typeId": "node.compressor_envelope", "handle": "env",
      "params": {
        "ratio":  { "type": "Float", "value": 0.5 },
        "punch":  { "type": "Float", "value": 0.5 },
        "target": { "type": "Float", "value": 0.5 }
      }
    },

    {
      "id": 30, "typeId": "node.gain", "handle": "gain",
      "params": {
        "gain": { "type": "Float", "value": 1.0 }
      }
    },

    {
      "id": 40, "typeId": "node.wet_dry", "handle": "wet_dry",
      "params": {
        "wet_dry": { "type": "Float", "value": 0.5 }
      }
    }
  ],
  "wires": [
    { "fromNode": 0,  "fromPort": "out", "toNode": 10, "toPort": "in" },
    { "fromNode": 10, "fromPort": "out", "toNode": 20, "toPort": "in" },

    { "fromNode": 0,  "fromPort": "out", "toNode": 30, "toPort": "in" },
    { "fromNode": 20, "fromPort": "out", "toNode": 30, "toPort": "gain" },

    { "fromNode": 0,  "fromPort": "out", "toNode": 40, "toPort": "dry" },
    { "fromNode": 30, "fromPort": "out", "toNode": 40, "toPort": "wet" },

    { "fromNode": 40, "fromPort": "out", "toNode": 99, "toPort": "in" }
  ]
}
