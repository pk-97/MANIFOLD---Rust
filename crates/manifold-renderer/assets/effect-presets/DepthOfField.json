{
  "version": 2,
  "name": "DepthOfField",
  "description": "Tranche 7 decomposition. Three CoC masks (box_mask for tilt-shift, ellipse_mask for radial, depth_estimate_midas → smoothstep chain for depth) feed a 3-way mux; the selected mask is inverted into a CoC, multiplied by blur_strength, clamped, and drives the per-pixel width of two gaussian_blur_variable_width passes (H then V, scatter-as-gather weighting for foreground-bleed prevention). The composite is a masked_mix of source over the blurred image. Depth-mode DNN cost is gated by mux short-circuit liveness pruning — depth_estimate_midas only runs when mode = Depth.",
  "presetMetadata": {
    "id": "DepthOfField",
    "displayName": "Depth of Field",
    "category": "Filmic",
    "oscPrefix": "dof",
    "legacyDiscriminant": 40,
    "available": true,
    "params": [
      { "id": "amount", "name": "Amount", "min": 0.0, "max": 1.0, "defaultValue": 1.0, "wholeNumbers": false, "isToggle": false, "formatString": "F2" },
      { "id": "mode", "name": "Mode", "min": 0.0, "max": 2.0, "defaultValue": 0.0, "wholeNumbers": true, "isToggle": false, "valueLabels": ["Tilt-Shift", "Radial", "Depth"], "oscSuffix": "Mode" },
      { "id": "focus", "name": "Focus", "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "FocusPosition" },
      { "id": "focus_x", "name": "Focus X", "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "FocusX" },
      { "id": "width", "name": "Width", "min": 0.01, "max": 0.5, "defaultValue": 0.15, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "FocusWidth" },
      { "id": "blur", "name": "Blur", "min": 0.0, "max": 1.0, "defaultValue": 0.5, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "BlurStrength" },
      { "id": "angle", "name": "Angle", "min": 0.0, "max": 360.0, "defaultValue": 0.0, "wholeNumbers": false, "isToggle": false, "formatString": "F2", "oscSuffix": "TiltAngle" },
      { "id": "quality", "name": "Quality", "min": 0.0, "max": 2.0, "defaultValue": 1.0, "wholeNumbers": true, "isToggle": false, "valueLabels": ["Low", "Medium", "High"], "oscSuffix": "Quality" }
    ],
    "bindings": [
      { "id": "amount", "label": "Amount", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "composite", "param": "amount" },
        "convert": { "type": "Float" } },
      { "id": "mode", "label": "Mode", "defaultValue": 0.0,
        "target": { "kind": "handleNode", "handle": "mask_mux", "param": "selector" },
        "convert": { "type": "Float" } },

      { "id": "focus", "label": "Focus", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "tilt_mask", "param": "cy" },
        "convert": { "type": "Float" } },
      { "id": "focus", "label": "Focus", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "radial_mask", "param": "cy" },
        "convert": { "type": "Float" } },
      { "id": "focus", "label": "Focus", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "neg_focus", "param": "a" },
        "convert": { "type": "Float" } },

      { "id": "focus_x", "label": "Focus X", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "radial_mask", "param": "cx" },
        "convert": { "type": "Float" } },

      { "id": "width", "label": "Width", "defaultValue": 0.15,
        "target": { "kind": "handleNode", "handle": "tilt_mask", "param": "half_height" },
        "convert": { "type": "Float" } },
      { "id": "width", "label": "Width", "defaultValue": 0.15,
        "target": { "kind": "handleNode", "handle": "radial_mask", "param": "radius_x" },
        "convert": { "type": "Float" } },
      { "id": "width", "label": "Width", "defaultValue": 0.15,
        "target": { "kind": "handleNode", "handle": "radial_mask", "param": "radius_y" },
        "convert": { "type": "Float" } },
      { "id": "width", "label": "Width", "defaultValue": 0.15,
        "target": { "kind": "handleNode", "handle": "inv_width", "param": "a" },
        "convert": { "type": "Float" } },

      { "id": "blur", "label": "Blur", "defaultValue": 0.5,
        "target": { "kind": "handleNode", "handle": "coc_strength", "param": "scale" },
        "convert": { "type": "Float" } },

      { "id": "angle", "label": "Angle", "defaultValue": 0.0,
        "target": { "kind": "handleNode", "handle": "rad_math", "param": "a" },
        "convert": { "type": "Float" } },

      { "id": "quality", "label": "Quality", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "blur_h", "param": "quality" },
        "convert": { "type": "EnumRound" } },
      { "id": "quality", "label": "Quality", "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "blur_v", "param": "quality" },
        "convert": { "type": "EnumRound" } }
    ],
    "skipMode": { "kind": "onZero", "paramId": "amount" }
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source" },
    { "id": 99, "typeId": "system.final_output", "handle": "final_output" },

    {
      "id": 10, "typeId": "node.math", "handle": "neg_focus",
      "params": {
        "a":  { "type": "Float", "value": 0.5 },
        "b":  { "type": "Float", "value": -1.0 },
        "op": { "type": "Enum", "value": 2 }
      }
    },
    {
      "id": 11, "typeId": "node.math", "handle": "inv_width",
      "params": {
        "a":  { "type": "Float", "value": 0.15 },
        "op": { "type": "Enum", "value": 9 }
      }
    },
    {
      "id": 12, "typeId": "node.math", "handle": "rad_math",
      "params": {
        "a":  { "type": "Float", "value": 0.0 },
        "b":  { "type": "Float", "value": 0.01745329 },
        "op": { "type": "Enum", "value": 2 }
      }
    },

    {
      "id": 20, "typeId": "node.box_mask", "handle": "tilt_mask",
      "params": {
        "cx":          { "type": "Float", "value": 0.5 },
        "cy":          { "type": "Float", "value": 0.5 },
        "half_width":  { "type": "Float", "value": 1.0 },
        "half_height": { "type": "Float", "value": 0.15 },
        "rotation":    { "type": "Float", "value": 0.0 },
        "softness":    { "type": "Float", "value": 0.5 }
      }
    },
    {
      "id": 21, "typeId": "node.ellipse_mask", "handle": "radial_mask",
      "params": {
        "cx":       { "type": "Float", "value": 0.5 },
        "cy":       { "type": "Float", "value": 0.5 },
        "radius_x": { "type": "Float", "value": 0.15 },
        "radius_y": { "type": "Float", "value": 0.15 },
        "rotation": { "type": "Float", "value": 0.0 },
        "softness": { "type": "Float", "value": 0.5 }
      }
    },

    {
      "id": 22, "typeId": "node.depth_estimate_midas", "handle": "depth_dnn",
      "params": {
        "analysis_max_dim": { "type": "Float", "value": 360.0 },
        "update_interval":  { "type": "Float", "value": 2.0 }
      }
    },
    {
      "id": 23, "typeId": "node.scale_offset_texture", "handle": "depth_centered",
      "params": {
        "scale":  { "type": "Float", "value": 1.0 },
        "offset": { "type": "Float", "value": 0.0 }
      }
    },
    {
      "id": 24, "typeId": "node.abs_texture", "handle": "depth_abs"
    },
    {
      "id": 25, "typeId": "node.scale_offset_texture", "handle": "depth_normalize",
      "params": {
        "scale":  { "type": "Float", "value": 1.0 },
        "offset": { "type": "Float", "value": -0.5 }
      }
    },
    {
      "id": 26, "typeId": "node.smoothstep_texture", "handle": "depth_to_mask",
      "params": {
        "low":  { "type": "Float", "value": 1.0 },
        "high": { "type": "Float", "value": 0.0 }
      }
    },

    {
      "id": 30, "typeId": "node.mux_texture", "handle": "mask_mux",
      "params": {
        "selector": { "type": "Float", "value": 0.0 }
      }
    },

    {
      "id": 31, "typeId": "node.invert", "handle": "to_coc",
      "params": {
        "intensity": { "type": "Float", "value": 1.0 }
      }
    },
    {
      "id": 32, "typeId": "node.scale_offset_texture", "handle": "coc_strength",
      "params": {
        "scale":  { "type": "Float", "value": 0.5 },
        "offset": { "type": "Float", "value": 0.0 }
      }
    },
    {
      "id": 33, "typeId": "node.clamp_texture", "handle": "coc_clamp",
      "params": {
        "min": { "type": "Float", "value": 0.0 },
        "max": { "type": "Float", "value": 1.0 }
      }
    },

    {
      "id": 40, "typeId": "node.gaussian_blur_variable_width", "handle": "blur_h",
      "params": {
        "axis":           { "type": "Enum",  "value": 0 },
        "max_radius":     { "type": "Float", "value": 6.0 },
        "quality":        { "type": "Enum",  "value": 1 },
        "weighting_mode": { "type": "Enum",  "value": 1 }
      }
    },
    {
      "id": 41, "typeId": "node.gaussian_blur_variable_width", "handle": "blur_v",
      "params": {
        "axis":           { "type": "Enum",  "value": 1 },
        "max_radius":     { "type": "Float", "value": 6.0 },
        "quality":        { "type": "Enum",  "value": 1 },
        "weighting_mode": { "type": "Enum",  "value": 1 }
      }
    },

    {
      "id": 50, "typeId": "node.masked_mix", "handle": "composite",
      "params": {
        "amount": { "type": "Float", "value": 1.0 }
      }
    }
  ],
  "wires": [
    { "fromNode": 0,  "fromPort": "out", "toNode": 22, "toPort": "in" },

    { "fromNode": 10, "fromPort": "out", "toNode": 23, "toPort": "offset" },
    { "fromNode": 22, "fromPort": "out", "toNode": 23, "toPort": "in" },
    { "fromNode": 23, "fromPort": "out", "toNode": 24, "toPort": "in" },
    { "fromNode": 24, "fromPort": "out", "toNode": 25, "toPort": "in" },
    { "fromNode": 11, "fromPort": "out", "toNode": 25, "toPort": "scale" },
    { "fromNode": 25, "fromPort": "out", "toNode": 26, "toPort": "in" },

    { "fromNode": 20, "fromPort": "out", "toNode": 30, "toPort": "in_0" },
    { "fromNode": 21, "fromPort": "out", "toNode": 30, "toPort": "in_1" },
    { "fromNode": 26, "fromPort": "out", "toNode": 30, "toPort": "in_2" },

    { "fromNode": 12, "fromPort": "out", "toNode": 20, "toPort": "rotation" },

    { "fromNode": 30, "fromPort": "out", "toNode": 31, "toPort": "in" },
    { "fromNode": 31, "fromPort": "out", "toNode": 32, "toPort": "in" },
    { "fromNode": 32, "fromPort": "out", "toNode": 33, "toPort": "in" },

    { "fromNode": 0,  "fromPort": "out", "toNode": 40, "toPort": "in" },
    { "fromNode": 33, "fromPort": "out", "toNode": 40, "toPort": "width" },
    { "fromNode": 40, "fromPort": "out", "toNode": 41, "toPort": "in" },
    { "fromNode": 33, "fromPort": "out", "toNode": 41, "toPort": "width" },

    { "fromNode": 0,  "fromPort": "out", "toNode": 50, "toPort": "a" },
    { "fromNode": 41, "fromPort": "out", "toNode": 50, "toPort": "b" },
    { "fromNode": 33, "fromPort": "out", "toNode": 50, "toPort": "mask" },

    { "fromNode": 50, "fromPort": "out", "toNode": 99, "toPort": "in" }
  ]
}
