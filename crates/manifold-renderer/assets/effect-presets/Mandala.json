{
  "version": 2,
  "name": "Mandala",
  "description": "Kaleidoscope-driven feedback. The source is folded by a kaleidoscope, then drifts through a rotating zoom-feedback loop assembled from primitives (feedback → affine → gain → vignette → mix), and finishes with a chromatic aberration spectrum. The slow rotation of the feedback creates the mandala's rotating petals.",
  "presetMetadata": {
    "id": "Mandala",
    "displayName": "Mandala",
    "category": "Stylize",
    "oscPrefix": "mandala",
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "segments",
        "name": "Segments",
        "min": 2.0,
        "max": 16.0,
        "defaultValue": 6.0,
        "wholeNumbers": true,
        "isToggle": false
      },
      {
        "id": "persistence",
        "name": "Persistence",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.7,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "zoom",
        "name": "Zoom",
        "min": 0.9,
        "max": 1.1,
        "defaultValue": 0.99,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F3"
      },
      {
        "id": "drift",
        "name": "Drift",
        "min": -10.0,
        "max": 10.0,
        "defaultValue": 1.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F1",
        "oscSuffix": "°/f"
      },
      {
        "id": "spectrum",
        "name": "Spectrum",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.4,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "handleNode",
          "handle": "kaleidoscope",
          "param": "amount"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "segments",
        "label": "Segments",
        "defaultValue": 6.0,
        "target": {
          "kind": "handleNode",
          "handle": "kaleidoscope",
          "param": "segments"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "persistence",
        "label": "Persistence",
        "defaultValue": 0.7,
        "target": {
          "kind": "handleNode",
          "handle": "gain",
          "param": "gain"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "zoom",
        "label": "Zoom",
        "defaultValue": 0.99,
        "target": {
          "kind": "handleNode",
          "handle": "affine",
          "param": "scale"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "drift",
        "label": "Drift",
        "defaultValue": 1.5,
        "target": {
          "kind": "handleNode",
          "handle": "affine",
          "param": "rotation"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "spectrum",
        "label": "Spectrum",
        "defaultValue": 0.4,
        "target": {
          "kind": "handleNode",
          "handle": "chromatic",
          "param": "amount"
        },
        "convert": { "type": "Float" }
      }
    ],
    "skipMode": { "kind": "onZero", "paramId": "amount" }
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source" },
    {
      "id": 1,
      "typeId": "node.kaleidoscope",
      "handle": "kaleidoscope",
      "params": {
        "amount": { "type": "Float", "value": 0.0 },
        "segments": { "type": "Int", "value": 6 }
      }
    },
    { "id": 2, "typeId": "node.feedback", "handle": "feedback" },
    {
      "id": 3,
      "typeId": "node.affine_transform",
      "handle": "affine",
      "params": {
        "scale": { "type": "Float", "value": 0.99 },
        "rotation": { "type": "Float", "value": 1.5 }
      }
    },
    {
      "id": 4,
      "typeId": "node.gain",
      "handle": "gain",
      "params": {
        "gain": { "type": "Float", "value": 0.7 }
      }
    },
    {
      "id": 5,
      "typeId": "node.vignette",
      "handle": "vignette",
      "params": {
        "shape": { "type": "Enum", "value": 2 },
        "size": { "type": "Float", "value": 0.98 },
        "softness": { "type": "Float", "value": 0.04 },
        "strength": { "type": "Float", "value": 1.0 }
      }
    },
    {
      "id": 6,
      "typeId": "node.mix",
      "handle": "mix",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 1 }
      }
    },
    {
      "id": 7,
      "typeId": "node.chromatic_aberration",
      "handle": "chromatic",
      "params": {
        "amount": { "type": "Float", "value": 0.0 },
        "angle": { "type": "Float", "value": 0.0 },
        "falloff": { "type": "Float", "value": 0.5 },
        "mode": { "type": "Enum", "value": 0 },
        "offset": { "type": "Float", "value": 0.01 }
      }
    },
    { "id": 8, "typeId": "system.final_output", "handle": "final_output" }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "out", "toNode": 1, "toPort": "in" },
    { "fromNode": 1, "fromPort": "out", "toNode": 6, "toPort": "a" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "in" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "in" },
    { "fromNode": 5, "fromPort": "out", "toNode": 6, "toPort": "b" },
    { "fromNode": 6, "fromPort": "out", "toNode": 2, "toPort": "in" },
    { "fromNode": 6, "fromPort": "out", "toNode": 7, "toPort": "in" },
    { "fromNode": 7, "fromPort": "out", "toNode": 8, "toPort": "in" }
  ]
}
