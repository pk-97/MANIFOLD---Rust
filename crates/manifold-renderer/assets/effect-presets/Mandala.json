  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "in"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "source"
    },
    {
      "fromNode": 2,
      "fromPort": "out",
      "toNode": 3,
      "toPort": "in"
    },
    {
      "fromNode": 3,
      "fromPort": "out",
      "toNode": 4,
      "toPort": "in"
    }
  ]
