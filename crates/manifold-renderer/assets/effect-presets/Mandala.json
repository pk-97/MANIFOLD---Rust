        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "segments",
        "name": "Segments",
        "min": 2.0,
        "max": 16.0,
        "defaultValue": 6.0,
        "wholeNumbers": true,
        "isToggle": false
      },
      {
        "id": "persistence",
        "name": "Persistence",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.7,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "zoom",
        "name": "Zoom",
        "min": 0.9,
        "max": 1.1,
        "defaultValue": 0.99,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F3"
      },
      {
        "id": "drift",
        "name": "Drift",
        "min": -10.0,
        "max": 10.0,
        "defaultValue": 1.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F1",
        "oscSuffix": "°/f"
      },
      {
        "id": "spectrum",
        "name": "Spectrum",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.4,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      }
