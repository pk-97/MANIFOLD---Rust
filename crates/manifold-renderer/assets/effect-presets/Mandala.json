        "rotation": {
          "type": "Float",
          "value": 0.0
        },
        "zoom": {
          "type": "Float",
          "value": 0.95
        }
      }
    },
    {
      "id": 3,
      "typeId": "node.chromatic_aberration",
      "handle": "chromatic",
      "params": {
        "amount": {
          "type": "Float",
          "value": 0.0
        },
        "angle": {
          "type": "Float",
          "value": 0.0
        },
        "falloff": {
          "type": "Float",
          "value": 0.5
        },
        "mode": {
          "type": "Enum",
          "value": 0
        },
        "offset": {
          "type": "Float",
          "value": 0.01
        }
      }
    },
    {
      "id": 4,
      "typeId": "system.final_output",
      "handle": "final_output"
    }
