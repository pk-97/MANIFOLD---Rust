        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "handleNode",
          "handle": "kaleidoscope",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "segments",
        "label": "Segments",
        "defaultValue": 6.0,
        "target": {
          "kind": "handleNode",
          "handle": "kaleidoscope",
          "param": "segments"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "persistence",
        "label": "Persistence",
        "defaultValue": 0.7,
        "target": {
          "kind": "handleNode",
          "handle": "feedback",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "zoom",
        "label": "Zoom",
        "defaultValue": 0.99,
        "target": {
          "kind": "handleNode",
          "handle": "feedback",
          "param": "zoom"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "drift",
        "label": "Drift",
        "defaultValue": 1.5,
        "target": {
          "kind": "handleNode",
          "handle": "feedback",
          "param": "rotation"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "spectrum",
        "label": "Spectrum",
        "defaultValue": 0.4,
        "target": {
          "kind": "handleNode",
          "handle": "chromatic",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
