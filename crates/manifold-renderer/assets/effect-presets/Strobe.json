{
  "version": 2,
  "name": "Strobe",
  "description": "Strobe, decomposed: node.beat_gate produces the beat-synced square gate (fract(beats*rate) >= 0.5 ? amount : 0, reading FrameTime.beats — identical to the legacy inline gate, proven by beat_gate's parity test), and node.flash applies it to the image in the selected mode (Opacity = toward black, White = toward white, Gain = 3x brighten). Replaces the fused node.strobe kernel; the gate is now a reusable wireable signal and the flash a reusable scalar-driven brightness modulator (drive it from an LFO/audio/MIDI too). No system.generator_input needed — beat_gate reads the beat from FrameTime.",
  "presetMetadata": {
    "id": "Strobe",
    "displayName": "Strobe",
    "category": "Stylize",
    "oscPrefix": "strobe",
    "legacyDiscriminant": 19,
