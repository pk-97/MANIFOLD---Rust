{
  "version": 2,
  "name": "EdgeStretch",
  "description": "Edge-stretch, decomposed: node.uv_strip_clamp builds the strip-clamped sample UV, node.remap resamples the source there, node.mix crossfades. Replaces the legacy node.edge_stretch bundle (bit-exact — the clamp shader is a verbatim port).",
  "presetMetadata": {
    "id": "EdgeStretch",
    "displayName": "Edge Stretch",
    "category": "Spatial",
    "oscPrefix": "edgeStretch",
    "legacyDiscriminant": 15,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "width",
        "name": "Width",
        "min": 0.1,
        "max": 0.9,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "SourceWidth"
      },
      {
        "id": "direction",
        "name": "Direction",
        "min": 0.0,
        "max": 2.0,
        "defaultValue": 0.0,
        "wholeNumbers": true,
        "isToggle": false,
        "valueLabels": [
          "Horiz",
          "Vert",
          "Both"
        ],
        "oscSuffix": "Direction"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "edge_stretch",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "width",
        "label": "Width",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "strip",
          "param": "width"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "direction",
        "label": "Direction",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "strip",
          "param": "direction"
        },
        "convert": {
          "type": "EnumRound"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    },
    "paramAliases": [
      {
        "old": "dir",
        "new": "direction"
      }
    ]
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source", "nodeId": "source"
    },
    {
      "id": 1,
      "typeId": "node.uv_strip_clamp",
      "handle": "strip", "nodeId": "strip",
      "params": {
        "width": { "type": "Float", "value": 0.5 },
        "direction": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 2,
      "typeId": "node.remap",
      "handle": "remapped", "nodeId": "remapped",
      "params": {
        "wrap": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 3,
      "typeId": "node.mix",
      "handle": "edge_stretch", "nodeId": "edge_stretch",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 4,
      "typeId": "system.final_output",
      "handle": "final_output", "nodeId": "final_output"
    }
  ],
  "wires": [
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "uv_field" },
    { "fromNode": 0, "fromPort": "out", "toNode": 2, "toPort": "source" },
    { "fromNode": 0, "fromPort": "out", "toNode": 3, "toPort": "a" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "b" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "in" }
  ]
}
