        "label": "Width",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "strip",
          "param": "width"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "direction",
        "label": "Direction",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "strip",
          "param": "direction"
