{
  "version": 2,
  "name": "EdgeStretch",
  "description": "Edge stretch remaps source material toward its edges: a decomposed, shaderless pipeline that builds on three atoms. The UV Strip Clamp shader resamples the source texture by clamping a sample width along one or both axes (horizontal, vertical, or both). Remapped Source then resamples the original at those clamped coordinates. Finally, Crossfade blends the remapped texture back toward the original, using the Amount parameter to dial the effect in and out from zero to full stretch. The result is the live input, preserving the performance surface bindings: Amount and Width drive the mix and clamp width, Direction routes to both stretch controls, and the preset skips when Amount is zero.",
  "presetMetadata": {
    "id": "EdgeStretch",
    "displayName": "Edge Stretch",
    "category": "Spatial",
    "oscPrefix": "edgeStretch",
    "legacyDiscriminant": 15,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "width",
        "name": "Width",
        "min": 0.1,
        "max": 0.9,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2",
        "oscSuffix": "SourceWidth"
      },
      {
        "id": "direction",
        "name": "Direction",
        "min": 0.0,
        "max": 2.0,
        "defaultValue": 0.0,
        "wholeNumbers": true,
        "isToggle": false,
        "isTrigger": false,
        "valueLabels": [
          "Horiz",
          "Vert",
          "Both"
        ],
        "oscSuffix": "Direction"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "edge_stretch",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
