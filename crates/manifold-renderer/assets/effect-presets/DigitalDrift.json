      },
      {
        "id": "speed",
        "label": "Speed",
        "defaultValue": 2.0,
        "target": { "kind": "node", "nodeId": "speed_value", "param": "value" },
        "convert": { "type": "Float" }
      },
      {
        "id": "bands",
        "label": "Bands",
        "defaultValue": 36.0,
        "target": { "kind": "node", "nodeId": "rows", "param": "bands" },
        "convert": { "type": "Float" }
      },
      {
        "id": "rgb_shift",
        "label": "RGB Shift",
        "defaultValue": 0.008,
        "target": { "kind": "node", "nodeId": "split", "param": "amount" },
