        "name": "Drift",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "speed",
        "name": "Speed",
        "min": 0.1,
        "max": 10.0,
        "defaultValue": 2.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Speed"
      },
      {
        "id": "bands",
        "name": "Bands",
        "min": 0.0,
        "max": 128.0,
        "defaultValue": 36.0,
        "wholeNumbers": true,
        "isToggle": false,
        "formatString": "F0",
        "oscSuffix": "Bands"
      },
      {
        "id": "rgb_shift",
        "name": "RGB Shift",
        "min": 0.0,
        "max": 0.03,
        "defaultValue": 0.008,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "RGBShift"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Drift",
        "defaultValue": 1.0,
        "target": { "kind": "node", "nodeId": "drift_amount", "param": "value" },
        "convert": { "type": "Float" }
      },
      {
        "id": "speed",
        "label": "Speed",
        "defaultValue": 2.0,
        "target": { "kind": "node", "nodeId": "rows", "param": "speed" },
        "convert": { "type": "Float" }
      },
      {
        "id": "bands",
        "label": "Bands",
        "defaultValue": 36.0,
        "target": { "kind": "node", "nodeId": "rows", "param": "bands" },
        "convert": { "type": "Float" }
      },
      {
        "id": "rgb_shift",
        "label": "RGB Shift",
        "defaultValue": 0.008,
