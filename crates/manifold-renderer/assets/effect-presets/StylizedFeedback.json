{
  "version": 2,
  "name": "StylizedFeedback",
  "description": "Feedback trails built from a simple cascade. The source image mixes with the prior frame delayed by one render, which gets zoomed and rotated, scaled by Amount, vignetted to hide edge artifacts from the transform, then Screen-blended back over the fresh input. The Amount slider gates the feedback intensity; Zoom and Rotate are direct transforms applied to history. The loop closes when the blended result recirculates through the feedback node's 1-frame delay, building persistent trails from the motion.",
  "presetMetadata": {
    "id": "StylizedFeedback",
    "displayName": "Stylized Feedback",
    "category": "Stylize",
    "oscPrefix": "stylizedFeedback",
    "legacyDiscriminant": 20,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "zoom",
        "name": "Zoom",
        "min": 0.9,
        "max": 1.1,
        "defaultValue": 0.95,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2",
        "oscSuffix": "Zoom"
      },
      {
        "id": "rotate",
        "name": "Rotate",
        "min": -10.0,
        "max": 10.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2",
        "oscSuffix": "Rotate"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "gain",
          "param": "gain"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "zoom",
        "label": "Zoom",
        "defaultValue": 0.95,
        "target": {
          "kind": "node",
          "nodeId": "affine",
          "param": "scale"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "rotate",
        "label": "Rotate",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "affine",
          "param": "rotation"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "never"
    }
  },
  "nodes": [
    {
      "id": 0,
      "nodeId": "source",
      "typeId": "system.source",
      "handle": "source",
      "title": "Source"
    },
    {
      "id": 1,
      "nodeId": "feedback",
      "typeId": "node.feedback",
      "handle": "feedback",
      "title": "Feedback"
    },
    {
      "id": 2,
      "nodeId": "affine",
      "typeId": "node.affine_transform",
      "handle": "affine",
      "params": {
        "rotation": {
          "type": "Float",
          "value": 0.0
        },
        "scale": {
          "type": "Float",
          "value": 0.95
        }
      },
      "title": "Zoom Rotate"
    },
    {
      "id": 3,
      "nodeId": "gain",
      "typeId": "node.gain",
      "handle": "gain",
      "params": {
        "gain": {
          "type": "Float",
          "value": 0.5
        }
      },
      "title": "Amount"
    },
    {
      "id": 4,
      "nodeId": "vignette",
      "typeId": "node.vignette",
      "handle": "vignette",
      "params": {
        "shape": {
          "type": "Enum",
          "value": 2
        },
        "size": {
          "type": "Float",
          "value": 0.98
        },
        "softness": {
          "type": "Float",
          "value": 0.04
        },
        "strength": {
          "type": "Float",
          "value": 1.0
        }
      },
      "title": "Vignette"
    },
    {
      "id": 5,
      "nodeId": "mix",
      "typeId": "node.mix",
      "handle": "mix",
      "params": {
        "amount": {
          "type": "Float",
          "value": 1.0
        },
        "mode": {
          "type": "Enum",
          "value": 1
        }
      },
      "title": "Screen Blend"
    },
    {
      "id": 6,
      "nodeId": "final_output",
      "typeId": "system.final_output",
      "handle": "final_output",
      "title": "Output"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 5,
      "toPort": "a"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "in"
    },
    {
      "fromNode": 2,
      "fromPort": "out",
      "toNode": 3,
      "toPort": "in"
    },
    {
      "fromNode": 3,
      "fromPort": "out",
      "toNode": 4,
      "toPort": "in"
    },
    {
      "fromNode": 4,
      "fromPort": "out",
      "toNode": 5,
      "toPort": "b"
    },
    {
      "fromNode": 5,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "in"
    },
    {
      "fromNode": 5,
      "fromPort": "out",
      "toNode": 6,
      "toPort": "in"
    }
  ]
}
