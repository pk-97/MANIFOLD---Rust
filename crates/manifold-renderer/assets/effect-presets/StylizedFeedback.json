{
  "version": 2,
  "name": "StylizedFeedback",
  "description": "Zoom/rotate/blend feedback chain built from primitives: feedback (1-frame delay) → affine_transform (zoom/rotate the previous frame) → gain (scale by Amount) → vignette (soft rectangular fade hides the displaced copy's hard edges) → mix (Screen-blend the source over the transformed history). The loop closes through the feedback node's state capture, exposed in the graph editor.",
  "presetMetadata": {
    "id": "StylizedFeedback",
    "displayName": "Stylized Feedback",
    "category": "Stylize",
    "oscPrefix": "stylizedFeedback",
    "legacyDiscriminant": 20,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "zoom",
        "name": "Zoom",
        "min": 0.9,
        "max": 1.1,
        "defaultValue": 0.95,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Zoom"
      },
      {
        "id": "rotate",
        "name": "Rotate",
        "min": -10.0,
        "max": 10.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Rotate"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "gain",
          "param": "gain"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "zoom",
        "label": "Zoom",
        "defaultValue": 0.95,
        "target": {
          "kind": "node",
          "nodeId": "affine",
          "param": "scale"
        },
        "convert": { "type": "Float" }
      },
      {
        "id": "rotate",
        "label": "Rotate",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "affine",
          "param": "rotation"
        },
        "convert": { "type": "Float" }
      }
    ],
    "skipMode": { "kind": "never" }
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source", "nodeId": "source" },
    { "id": 1, "typeId": "node.feedback", "handle": "feedback", "nodeId": "feedback" },
    {
      "id": 2,
      "typeId": "node.affine_transform",
      "handle": "affine", "nodeId": "affine",
      "params": {
        "scale": { "type": "Float", "value": 0.95 },
        "rotation": { "type": "Float", "value": 0.0 }
      }
    },
    {
      "id": 3,
      "typeId": "node.gain",
      "handle": "gain", "nodeId": "gain",
      "params": {
        "gain": { "type": "Float", "value": 0.5 }
      }
    },
    {
      "id": 4,
      "typeId": "node.vignette",
      "handle": "vignette", "nodeId": "vignette",
      "params": {
        "shape": { "type": "Enum", "value": 2 },
        "size": { "type": "Float", "value": 0.98 },
        "softness": { "type": "Float", "value": 0.04 },
        "strength": { "type": "Float", "value": 1.0 }
      }
    },
    {
      "id": 5,
      "typeId": "node.mix",
      "handle": "mix", "nodeId": "mix",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 1 }
      }
    },
    { "id": 6, "typeId": "system.final_output", "handle": "final_output", "nodeId": "final_output" }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "out", "toNode": 5, "toPort": "a" },
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "in" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "in" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "b" },
    { "fromNode": 5, "fromPort": "out", "toNode": 1, "toPort": "in" },
    { "fromNode": 5, "fromPort": "out", "toNode": 6, "toPort": "in" }
  ]
}
