{
  "version": 2,
  "name": "SoftFocus",
  "description": "A soft-focus effect that blends the source image with a blurred copy at variable intensity. The source image feeds both the Blur node (which softens it using a Gaussian kernel at the Radius parameter) and the Mix node directly. The Blur output and the original then blend at the Mix stage, controlled by the Amount slider. At Amount zero the effect is skipped and the output is the raw input; at Amount one it reaches full softening. Blur mode and Mix mode are both fixed to their defaults, so the only live parameters are Radius and Amount.",
  "presetMetadata": {
    "id": "SoftFocus",
    "displayName": "Soft Focus",
    "category": "Stylize",
    "oscPrefix": "soft_focus_graph",
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "radius",
        "name": "Radius",
        "min": 0.0,
        "max": 64.0,
        "defaultValue": 6.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F1",
        "oscSuffix": "px"
      },
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "radius",
        "label": "Radius",
        "defaultValue": 6.0,
        "target": {
          "kind": "node",
          "nodeId": "blur",
          "param": "radius"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "mix",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "nodeId": "source",
      "typeId": "system.source",
      "handle": "source",
      "title": "Source"
    },
    {
      "id": 1,
      "nodeId": "blur",
      "typeId": "node.blur",
      "handle": "blur",
      "params": {
        "mode": {
          "type": "Enum",
          "value": 0
        },
        "radius": {
          "type": "Float",
          "value": 4.0
        }
      },
      "title": "Blur"
    },
    {
      "id": 2,
      "nodeId": "mix",
      "typeId": "node.mix",
      "handle": "mix",
      "params": {
        "amount": {
          "type": "Float",
          "value": 0.5
        },
        "mode": {
          "type": "Enum",
          "value": 0
        }
      },
      "title": "Blend"
    },
    {
      "id": 3,
      "nodeId": "final_output",
      "typeId": "system.final_output",
      "handle": "final_output",
      "title": "Output"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "source"
    },
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "a"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "b"
    },
    {
      "fromNode": 2,
      "fromPort": "out",
      "toNode": 3,
      "toPort": "in"
    }
  ]
}
