{
  "version": 2,
  "name": "Invert",
  "description": "Invert Colors is a simple, single-stage effect that reads the incoming image and inverts all RGB values per pixel. The Amount slider controls the strength of the inversion applied by the core node: at 0.0 no inversion occurs (effect is skipped); at 1.0 (default) colors are fully inverted. Pass this effect through to the output with the inverted result.",
  "presetMetadata": {
    "id": "Invert",
    "displayName": "Invert",
    "category": "Color",
    "oscPrefix": "invert",
    "legacyDiscriminant": 1,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "invert",
          "param": "intensity"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "nodeId": "source",
      "typeId": "system.source",
      "handle": "source",
      "title": "Source"
    },
    {
      "id": 1,
      "nodeId": "invert",
      "typeId": "node.invert",
      "handle": "invert",
      "params": {
        "intensity": {
          "type": "Float",
          "value": 1.0
        }
      },
      "title": "Invert"
    },
    {
      "id": 2,
      "nodeId": "final_output",
      "typeId": "system.final_output",
      "handle": "final_output",
      "title": "Output"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "in"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "in"
    }
  ]
}
