{
  "version": 2,
  "name": "ChromaticAberration",
  "description": "RGB channel separation, decomposed: node.radial_offset_field builds the radial/linear direction field, node.math scales the UV-space `offset` into a (negated) pixel displacement, node.chromatic_displace does the 3-tap RGB recombine (R outward, G center, B inward), node.mix crossfades by `amount`. Replaces the fused node.chromatic_aberration kernel. Visual delta vs legacy: chromatic_displace divides by dims so the split is isotropic in pixels (round halo) where the legacy added a raw UV offset (anisotropic / elliptical). Same controls, same look family; verified by eye.",
  "presetMetadata": {
    "id": "ChromaticAberration",
    "displayName": "Chromatic Aberration",
    "category": "Filmic",
    "oscPrefix": "chromAb",
    "legacyDiscriminant": 30,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "offset",
        "name": "Offset",
        "min": 0.0,
        "max": 0.05,
        "defaultValue": 0.01,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Offset"
      },
      {
        "id": "mode",
        "name": "Mode",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.0,
        "wholeNumbers": true,
        "isToggle": false,
        "valueLabels": [
          "Radial",
          "Linear"
        ],
        "oscSuffix": "Mode"
      },
      {
        "id": "angle",
        "name": "Angle",
        "min": 0.0,
        "max": 360.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Angle"
      },
      {
        "id": "falloff",
        "name": "Falloff",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Falloff"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "chromatic",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "offset",
        "label": "Offset",
        "defaultValue": 0.01,
        "target": {
          "kind": "node",
          "nodeId": "offset_scale",
          "param": "a"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "mode",
        "label": "Mode",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "field",
          "param": "mode"
        },
        "convert": {
          "type": "EnumRound"
        }
      },
      {
        "id": "angle",
        "label": "Angle",
        "defaultValue": 0.0,
        "target": {
          "kind": "node",
          "nodeId": "field",
          "param": "angle"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "falloff",
        "label": "Falloff",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "field",
          "param": "falloff"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source", "nodeId": "source"
    },
    {
      "id": 1,
      "typeId": "node.radial_offset_field",
      "handle": "field", "nodeId": "field",
      "params": {
        "mode": { "type": "Enum", "value": 0 },
        "angle": { "type": "Float", "value": 0.0 },
        "falloff": { "type": "Float", "value": 0.5 }
      }
    },
    {
      "id": 2,
      "typeId": "node.math",
      "handle": "offset_scale", "nodeId": "offset_scale",
      "params": {
        "a": { "type": "Float", "value": 0.01 },
        "b": { "type": "Float", "value": -1000.0 },
        "op": { "type": "Enum", "value": 2 }
      }
    },
    {
      "id": 3,
      "typeId": "node.chromatic_displace",
      "handle": "split", "nodeId": "split",
      "params": {
        "amount": { "type": "Float", "value": -10.0 }
      }
    },
    {
      "id": 4,
      "typeId": "node.mix",
      "handle": "chromatic", "nodeId": "chromatic",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 5,
      "typeId": "system.final_output",
      "handle": "final_output", "nodeId": "final_output"
    }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 1, "fromPort": "out", "toNode": 3, "toPort": "velocity" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "amount" },
    { "fromNode": 0, "fromPort": "out", "toNode": 4, "toPort": "a" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "b" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "in" }
  ]
}
