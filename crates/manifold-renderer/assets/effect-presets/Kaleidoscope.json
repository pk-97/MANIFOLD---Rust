{
  "version": 2,
  "name": "Kaleidoscope",
  "description": "Polar segment-mirror, decomposed: node.radial_fold_uv builds the folded sample UV, node.remap resamples the source there, node.mix crossfades. Replaces the legacy node.kaleidoscope bundle (bit-exact — the fold shader is a verbatim port).",
  "presetMetadata": {
    "id": "Kaleidoscope",
    "displayName": "Kaleidoscope",
    "category": "Spatial",
    "oscPrefix": "kaleidoscope",
    "legacyDiscriminant": 14,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "segments",
        "name": "Segments",
        "min": 2.0,
        "max": 16.0,
        "defaultValue": 6.0,
        "wholeNumbers": true,
        "isToggle": false,
        "oscSuffix": "Segments"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "handleNode",
          "handle": "kaleidoscope",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "segments",
        "label": "Segments",
        "defaultValue": 6.0,
        "target": {
          "kind": "handleNode",
          "handle": "fold",
          "param": "segments"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    },
    "paramAliases": [
      {
        "old": "segs",
        "new": "segments"
      }
    ]
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source"
    },
    {
      "id": 1,
      "typeId": "node.radial_fold_uv",
      "handle": "fold",
      "params": {
        "segments": { "type": "Float", "value": 6.0 },
        "cx": { "type": "Float", "value": 0.5 },
        "cy": { "type": "Float", "value": 0.5 }
      }
    },
    {
      "id": 2,
      "typeId": "node.remap",
      "handle": "remapped",
      "params": {
        "wrap": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 3,
      "typeId": "node.mix",
      "handle": "kaleidoscope",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 4,
      "typeId": "system.final_output",
      "handle": "final_output"
    }
  ],
  "wires": [
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "uv_field" },
    { "fromNode": 0, "fromPort": "out", "toNode": 2, "toPort": "source" },
    { "fromNode": 0, "fromPort": "out", "toNode": 3, "toPort": "a" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "b" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "in" }
  ]
}
