{
  "version": 2,
  "name": "VoronoiPrism",
  "description": "Canonical default graph generated from ChainSpec::splice.",
  "presetMetadata": {
    "id": "VoronoiPrism",
    "displayName": "Voronoi Prism",
    "category": "Stylize",
    "oscPrefix": "voronoiPrism",
    "legacyDiscriminant": 16,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "cells",
        "name": "Cells",
        "min": 4.0,
        "max": 64.0,
        "defaultValue": 16.0,
        "wholeNumbers": true,
        "isToggle": false,
        "oscSuffix": "CellCount"
      },
      {
        "id": "source_width",
        "name": "Cell Size",
        "min": 0.1,
        "max": 1.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "SourceWidth"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "handleNode",
          "handle": "voronoi",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "cells",
        "label": "Cells",
        "defaultValue": 16.0,
        "target": {
          "kind": "handleNode",
          "handle": "voronoi",
          "param": "cell_count"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "source_width",
        "label": "Cell Size",
        "defaultValue": 0.5,
        "target": {
          "kind": "handleNode",
          "handle": "voronoi",
          "param": "source_width"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source"
    },
    {
      "id": 1,
      "typeId": "node.voronoi_prism",
      "handle": "voronoi",
      "params": {
        "amount": {
          "type": "Float",
          "value": 0.0
        },
        "beat": {
          "type": "Float",
          "value": 0.0
        },
        "cell_count": {
          "type": "Int",
          "value": 16
        },
        "source_width": {
          "type": "Float",
          "value": 0.5
        }
      }
    },
    {
      "id": 2,
      "typeId": "system.final_output",
      "handle": "final_output"
    },
    {
      "id": 3,
      "typeId": "system.generator_input",
      "handle": "input"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "in"
    },
    {
      "fromNode": 3,
      "fromPort": "beat",
      "toNode": 1,
      "toPort": "beat"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "in"
    }
  ]
}
