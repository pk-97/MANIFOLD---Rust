{
  "version": 2,
  "name": "QuadMirror",
  "description": "Center-symmetric 4-way UV fold, decomposed: centered_uv → abs → scale_offset builds the mirrored UV field, node.remap resamples the source there, node.mix crossfades. Replaces the legacy node.quad_mirror bundle.",
  "presetMetadata": {
    "id": "QuadMirror",
    "displayName": "Quad Mirror",
    "category": "Spatial",
    "oscPrefix": "quadMirror",
    "legacyDiscriminant": 17,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "quad_mirror",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source", "nodeId": "source"
    },
    {
      "id": 1,
      "typeId": "node.centered_uv",
      "handle": "center", "nodeId": "center",
      "params": {
        "cx": { "type": "Float", "value": 0.5 },
        "cy": { "type": "Float", "value": 0.5 },
        "scale_x": { "type": "Float", "value": 1.0 },
        "scale_y": { "type": "Float", "value": 1.0 }
      }
    },
    {
      "id": 2,
      "typeId": "node.abs_texture",
      "handle": "fold", "nodeId": "fold"
    },
    {
      "id": 3,
      "typeId": "node.scale_offset_texture",
      "handle": "mirror_uv", "nodeId": "mirror_uv",
      "params": {
        "scale": { "type": "Float", "value": -2.0 },
        "offset": { "type": "Float", "value": 1.0 }
      }
    },
    {
      "id": 4,
      "typeId": "node.remap",
      "handle": "remapped", "nodeId": "remapped",
      "params": {
        "wrap": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 5,
      "typeId": "node.mix",
      "handle": "quad_mirror", "nodeId": "quad_mirror",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 6,
      "typeId": "system.final_output",
      "handle": "final_output", "nodeId": "final_output"
    }
  ],
  "wires": [
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "in" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 0, "fromPort": "out", "toNode": 4, "toPort": "source" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "uv_field" },
    { "fromNode": 0, "fromPort": "out", "toNode": 5, "toPort": "a" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "b" },
    { "fromNode": 5, "fromPort": "out", "toNode": 6, "toPort": "in" }
  ]
}
