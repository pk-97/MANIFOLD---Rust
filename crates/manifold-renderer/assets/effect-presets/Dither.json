{
  "version": 2,
  "name": "Dither",
  "description": "Dither, decomposed: node.dither_pattern generates the per-pixel ordered-dither / halftone threshold (the six classic algorithms), and node.dither does the luminance-preserving dither-biased quantize + hue rescale + crossfade reading that pattern. Replaces the fused node.dither kernel — bit-exact (the quantize math is verbatim; only the threshold source moved to an atom). The pattern generator is now reusable: feed it to other halftone consumers, or feed node.dither a BYO threshold texture.",
  "presetMetadata": {
    "id": "Dither",
    "displayName": "Dither",
    "category": "Color",
    "oscPrefix": "dither",
    "legacyDiscriminant": 18,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "pattern",
        "name": "Pattern",
        "min": 0.0,
        "max": 5.0,
        "defaultValue": 0.0,
        "wholeNumbers": true,
        "isToggle": false,
        "valueLabels": [
          "Bayer",
          "Halftone",
          "Lines",
          "X-Hatch",
          "Noise",
          "Diamond"
        ],
        "oscSuffix": "Algorithm"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": { "kind": "node", "nodeId": "dither", "param": "amount" },
        "convert": { "type": "Float" }
      },
      {
        "id": "pattern",
        "label": "Pattern",
        "defaultValue": 0.0,
        "target": { "kind": "node", "nodeId": "pattern", "param": "algorithm" },
        "convert": { "type": "EnumRound" }
      }
    ],
    "skipMode": { "kind": "onZero", "paramId": "amount" },
    "paramAliases": [
      { "old": "algo", "new": "pattern" }
    ]
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source", "nodeId": "source" },
    {
      "id": 1,
      "typeId": "node.dither_pattern",
      "handle": "pattern", "nodeId": "pattern",
      "params": {
        "algorithm": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 2,
      "typeId": "node.dither",
      "handle": "dither", "nodeId": "dither",
      "params": {
        "amount": { "type": "Float", "value": 0.0 }
      }
    },
    { "id": 3, "typeId": "system.final_output", "handle": "final_output", "nodeId": "final_output" }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "out", "toNode": 2, "toPort": "in" },
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "pattern" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" }
  ]
}
