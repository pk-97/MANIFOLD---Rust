{
  "version": 2,
  "name": "FilmGrain",
  "description": "Animated film grain, meant to sit last in a chain. Random per-pixel noise re-rolls every frame (the time input jitters the hash field's offset so grain never slides or freezes), gets splatted to monochrome by the Channel Mixer, and composites over the source in Overlay mode - grain rides the midtones and stays out of deep blacks and clipped whites, the way emulsion grain behaves.\n\nAmount is the wet control; at zero the source passes through untouched. Size scales the grain structure from fine (low values) to coarse (high values) by dividing the noise field's cell density.\n\nDoubles as a banding fix: slow smooth gradients that posterize on an 8-bit display dissolve under even a low Amount, because the grain dithers the final quantization step.",
  "presetMetadata": {
    "id": "FilmGrain",
    "displayName": "Film Grain",
    "category": "Stylize",
    "oscPrefix": "film_grain",
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.35,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "size",
        "name": "Size",
        "min": 1.0,
        "max": 8.0,
        "defaultValue": 1.6,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F1"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.35,
        "target": {
          "kind": "node",
          "nodeId": "grain_mix",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "size",
        "label": "Size",
        "defaultValue": 1.6,
        "target": {
          "kind": "node",
          "nodeId": "grain_size_to_scale",
          "param": "b"
        },
        "convert": {
          "type": "Float"
        }
      }
    ]
  },
  "nodes": [
