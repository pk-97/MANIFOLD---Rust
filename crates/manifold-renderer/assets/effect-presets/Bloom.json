{
  "version": 2,
  "name": "Bloom",
  "description": "Bloom, decomposed: node.threshold extracts the bright pass with a soft knee (the legacy bloom prefilter curve), node.downsample drops to quarter-res, an H+V pair of node.gaussian_blur in Linear mode (the exact port of the old node.blur pass) softens it cheaply, node.mix (Add) layers the glow back over the source by `amount`. Replaces the fused node.bloom kernel. Visual delta vs legacy: a single downsample+gaussian instead of the legacy 3-level Blur9/Blur13 mip pyramid, and `amount` scales glow intensity only (the legacy also widened the radius with amount) — same family, simpler/wider-fixed glow. Verified by eye.",
  "presetMetadata": {
    "id": "Bloom",
    "displayName": "Bloom",
    "category": "Filmic",
    "oscPrefix": "bloom",
    "legacyDiscriminant": 12,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 5.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": { "kind": "node", "nodeId": "bloom", "param": "amount" },
        "convert": { "type": "Float" }
      }
    ],
    "skipMode": { "kind": "onZero", "paramId": "amount" }
  },
  "nodes": [
    { "id": 0, "typeId": "system.source", "handle": "source", "nodeId": "source" },
    {
      "id": 1,
      "typeId": "node.threshold",
      "handle": "prefilter", "nodeId": "prefilter",
      "params": {
        "level": { "type": "Float", "value": 0.42 },
        "softness": { "type": "Float", "value": 0.24 }
      }
    },
    {
      "id": 2,
      "typeId": "node.downsample",
      "handle": "downsample", "nodeId": "downsample",
      "params": {
        "factor": { "type": "Enum", "value": 1 }
      }
    },
    {
      "id": 3,
      "typeId": "node.gaussian_blur",
      "handle": "blur_h", "nodeId": "blur_h",
      "params": {
        "radius_mode": { "type": "Enum", "value": 2 },
        "radius": { "type": "Float", "value": 8.0 },
        "axis": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 6,
      "typeId": "node.gaussian_blur",
      "handle": "blur_v", "nodeId": "blur_v",
      "params": {
        "radius_mode": { "type": "Enum", "value": 2 },
        "radius": { "type": "Float", "value": 8.0 },
        "axis": { "type": "Enum", "value": 1 }
      }
    },
    {
      "id": 4,
      "typeId": "node.mix",
      "handle": "bloom", "nodeId": "bloom",
      "params": {
        "amount": { "type": "Float", "value": 0.5 },
        "mode": { "type": "Enum", "value": 2 }
      }
    },
    { "id": 5, "typeId": "system.final_output", "handle": "final_output", "nodeId": "final_output" }
  ],
  "wires": [
    { "fromNode": 0, "fromPort": "out", "toNode": 1, "toPort": "source" },
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "in" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "in" },
    { "fromNode": 3, "fromPort": "out", "toNode": 6, "toPort": "in" },
    { "fromNode": 0, "fromPort": "out", "toNode": 4, "toPort": "a" },
    { "fromNode": 6, "fromPort": "out", "toNode": 4, "toPort": "b" },
    { "fromNode": 4, "fromPort": "out", "toNode": 5, "toPort": "in" }
  ]
}
