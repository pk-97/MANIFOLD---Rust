{
  "version": 2,
  "name": "Bloom",
  "description": "Glow effect, decomposed: brightness thresholding with soft knee extracts the bright pass (the bloom prefilter curve), downsampling drops to quarter resolution, separable horizontal and vertical Gaussian blur in Linear mode soften the glow with a fixed radius (the exact algorithm of the legacy blur pass), and additive blending layers the glow back over the source image. The amount slider controls glow intensity only, not blur radius like the legacy monolithic bloom kernel. Visual delta vs the old approach: a single downsample-and-blur instead of the legacy multi-level pyramid, yielding a simpler, wider fixed-radius glow. Verified by eye.",
  "presetMetadata": {
    "id": "Bloom",
    "displayName": "Bloom",
    "category": "Filmic",
    "oscPrefix": "bloom",
    "legacyDiscriminant": 12,
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 5.0,
        "defaultValue": 0.5,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 0.5,
        "target": {
          "kind": "node",
          "nodeId": "bloom",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    }
  },
  "nodes": [
    {
      "id": 0,
      "nodeId": "source",
      "typeId": "system.source",
      "handle": "source",
      "title": "Source"
    },
    {
      "id": 1,
      "nodeId": "prefilter",
      "typeId": "node.threshold",
      "handle": "prefilter",
      "params": {
        "level": {
          "type": "Float",
          "value": 0.42
        },
        "softness": {
          "type": "Float",
          "value": 0.24
        }
      },
      "title": "Bright Pass"
    },
    {
      "id": 2,
      "nodeId": "downsample",
      "typeId": "node.downsample",
      "handle": "downsample",
      "params": {
        "factor": {
          "type": "Enum",
          "value": 1
        }
      },
      "title": "Downsample"
    },
    {
      "id": 3,
      "nodeId": "blur_h",
      "typeId": "node.gaussian_blur",
      "handle": "blur_h",
      "params": {
        "axis": {
          "type": "Enum",
          "value": 0
        },
        "radius": {
          "type": "Float",
          "value": 8.0
        },
        "radius_mode": {
          "type": "Enum",
          "value": 2
        }
      },
      "title": "Blur Horizontal"
    },
    {
      "id": 6,
      "nodeId": "blur_v",
      "typeId": "node.gaussian_blur",
      "handle": "blur_v",
      "params": {
        "axis": {
          "type": "Enum",
          "value": 1
        },
        "radius": {
          "type": "Float",
          "value": 8.0
        },
        "radius_mode": {
          "type": "Enum",
          "value": 2
        }
      },
      "title": "Blur Vertical"
    },
    {
      "id": 4,
      "nodeId": "bloom",
      "typeId": "node.mix",
      "handle": "bloom",
      "params": {
        "amount": {
          "type": "Float",
          "value": 0.5
        },
        "mode": {
          "type": "Enum",
          "value": 2
        }
      },
      "title": "Blend Glow"
    },
    {
      "id": 5,
      "nodeId": "final_output",
      "typeId": "system.final_output",
      "handle": "final_output",
      "title": "Output"
    }
  ],
  "wires": [
    {
      "fromNode": 0,
      "fromPort": "out",
      "toNode": 1,
      "toPort": "source"
    },
    {
      "fromNode": 1,
      "fromPort": "out",
      "toNode": 2,
      "toPort": "in"
    },
    {
      "fromNode": 2,
      "fromPort": "out",
      "toNode": 3,
      "toPort": "in"
    },
    {
      "fromNode": 3,
