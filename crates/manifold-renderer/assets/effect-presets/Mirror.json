{
  "version": 2,
  "name": "Mirror",
  "description": "Axis mirror / kaleidoscope-fold, decomposed: node.mirror_fold_uv rewrites the per-pixel sample UV for the selected mode (flip / QuadMirror / Fold X/Y/Both), node.remap resamples the source there, node.mix crossfades by amount. Replaces the legacy node.transform mirror-mode kernel (bit-exact — the fold math is a verbatim port; the affine half of node.transform belongs to node.affine_transform).",
  "presetMetadata": {
    "id": "Mirror",
    "displayName": "Mirror",
    "category": "Spatial",
    "oscPrefix": "mirror",
    "legacyDiscriminant": 21,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "mode",
        "name": "Mode",
        "min": 0.0,
        "max": 8.0,
        "defaultValue": 6.0,
        "wholeNumbers": true,
        "isToggle": false,
        "valueLabels": [
          "Identity",
          "Mirror",
          "MirrorX",
          "MirrorY",
          "FlipY",
          "QuadMirror",
          "FoldX",
          "FoldY",
          "FoldBoth"
        ],
        "oscSuffix": "Mode"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "mix",
          "param": "amount"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "mode",
        "label": "Mode",
        "defaultValue": 6.0,
        "target": {
          "kind": "node",
          "nodeId": "uv_transform",
          "param": "mode"
        },
        "convert": {
          "type": "EnumRound"
        }
      }
    ],
    "skipMode": {
      "kind": "onZero",
      "paramId": "amount"
    },
    "valueAliases": [
      {
        "paramId": "mode",
        "mapping": [
          [
            0,
            6
          ],
          [
            1,
            7
          ],
          [
            2,
            8
          ]
        ]
      }
    ]
  },
  "nodes": [
    {
      "id": 0,
      "typeId": "system.source",
      "handle": "source", "nodeId": "source"
    },
    {
      "id": 1,
      "typeId": "node.mirror_fold_uv",
      "handle": "uv_transform", "nodeId": "uv_transform",
      "params": {
        "mode": { "type": "Enum", "value": 6 }
      }
    },
    {
      "id": 2,
      "typeId": "node.remap",
      "handle": "remapped", "nodeId": "remapped",
      "params": {
        "wrap": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 3,
      "typeId": "node.mix",
      "handle": "mix", "nodeId": "mix",
      "params": {
        "amount": { "type": "Float", "value": 1.0 },
        "mode": { "type": "Enum", "value": 0 }
      }
    },
    {
      "id": 4,
      "typeId": "system.final_output",
      "handle": "final_output", "nodeId": "final_output"
    }
  ],
  "wires": [
    { "fromNode": 1, "fromPort": "out", "toNode": 2, "toPort": "uv_field" },
    { "fromNode": 0, "fromPort": "out", "toNode": 2, "toPort": "source" },
    { "fromNode": 0, "fromPort": "out", "toNode": 3, "toPort": "a" },
    { "fromNode": 2, "fromPort": "out", "toNode": 3, "toPort": "b" },
    { "fromNode": 3, "fromPort": "out", "toNode": 4, "toPort": "in" }
  ]
