{
  "version": 2,
  "name": "Glitch",
  "description": "Glitch, decomposed: node.glitch_displace generates the block-displacement + scanline-jitter sampling-UV field (RG) plus a per-block invert accent mask; node.remap warps the source by that field; node.chromatic_aberration (Linear) does the RGB channel split; node.invert + node.masked_mix apply the per-block colour invert; node.mix (Lerp, amount) crossfades the whole thing back over the source. Replaces the fused 4-op node.glitch kernel (block displace + scanline + RGB split + per-block invert) — the displacement math is verbatim; the chromatic split + invert are now general atoms. node.value fans the master `amount` to both the displacement field and the final crossfade. Documented visual deltas vs legacy: the chromatic split uses a fixed angle (legacy rotates it per time-step) and a fixed rgb_shift offset (legacy scales it by amount, which the final crossfade now handles); within-block the chromatic sampling is identical, differing only at block boundaries. Time read from FrameTime.seconds — no generator_input needed.",
  "presetMetadata": {
    "id": "Glitch",
    "displayName": "Glitch",
    "category": "Filmic",
    "oscPrefix": "glitch",
    "legacyDiscriminant": 32,
    "available": true,
    "params": [
      {
        "id": "amount",
        "name": "Amount",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2"
      },
      {
        "id": "block_size",
        "name": "Block Size",
        "min": 4.0,
        "max": 64.0,
        "defaultValue": 16.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "BlockSize"
      },
      {
        "id": "rgb_shift",
        "name": "RGB Shift",
        "min": 0.0,
        "max": 0.05,
        "defaultValue": 0.01,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "RGBShift"
      },
      {
        "id": "scanline",
        "name": "Scanline",
        "min": 0.0,
        "max": 1.0,
        "defaultValue": 0.3,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Scanline"
      },
      {
        "id": "speed",
        "name": "Speed",
        "min": 0.1,
        "max": 10.0,
        "defaultValue": 2.0,
        "wholeNumbers": false,
        "isToggle": false,
        "formatString": "F2",
        "oscSuffix": "Speed"
      }
    ],
    "bindings": [
      {
        "id": "amount",
        "label": "Amount",
        "defaultValue": 1.0,
        "target": { "kind": "handleNode", "handle": "amount_value", "param": "value" },
        "convert": { "type": "Float" }
      },
      {
        "id": "block_size",
        "label": "Block Size",
        "defaultValue": 16.0,
        "target": { "kind": "handleNode", "handle": "displace", "param": "block_size" },
        "convert": { "type": "Float" }
      },
      {
        "id": "rgb_shift",
        "label": "RGB Shift",
        "defaultValue": 0.01,
        "target": { "kind": "handleNode", "handle": "split", "param": "offset" },
        "convert": { "type": "Float" }
      },
      {
        "id": "scanline",
        "label": "Scanline",
        "defaultValue": 0.3,
        "target": { "kind": "handleNode", "handle": "displace", "param": "scanline" },
        "convert": { "type": "Float" }
      },
      {
        "id": "speed",
        "label": "Speed",
        "defaultValue": 2.0,
        "target": { "kind": "handleNode", "handle": "displace", "param": "speed" },
        "convert": { "type": "Float" }
      }
    ],
