    { "fromNode": 5, "fromPort": "out", "toNode": 6, "toPort": "b" },
    { "fromNode": 2, "fromPort": "mask", "toNode": 6, "toPort": "mask" },
    { "fromNode": 0, "fromPort": "out", "toNode": 7, "toPort": "a" },
    { "fromNode": 6, "fromPort": "out", "toNode": 7, "toPort": "b" },
    { "fromNode": 1, "fromPort": "out", "toNode": 7, "toPort": "amount" },
    { "fromNode": 7, "fromPort": "out", "toNode": 8, "toPort": "in" }
