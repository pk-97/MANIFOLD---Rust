      "wgslSource": "// Gray-Scott substep 4 of 4 \u2014 same kernel as React 1 minus the inject\n// stamp (see React 1's header; Sims 9-point Laplacian, fp32 load-bearing).\nstruct Params { feed: f32, kill: f32, diff_u: f32, diff_v: f32, dt: f32, };\n@group(0) @binding(0) var<uniform> u: Params;\n@group(0) @binding(1) var field: texture_2d<f32>;\n@group(0) @binding(2) var output_tex: texture_storage_2d<rgba32float, write>;\n\n@compute @workgroup_size(16, 16)\nfn cs_main(@builtin(global_invocation_id) id: vec3<u32>) {\n    let dims = vec2<i32>(textureDimensions(output_tex));\n    let p = vec2<i32>(id.xy);\n    if p.x >= dims.x || p.y >= dims.y { return; }\n    let c  = textureLoad(field, p, 0).rg;\n    let l  = textureLoad(field, vec2<i32>(max(p.x - 1, 0), p.y), 0).rg;\n    let r  = textureLoad(field, vec2<i32>(min(p.x + 1, dims.x - 1), p.y), 0).rg;\n    let t  = textureLoad(field, vec2<i32>(p.x, max(p.y - 1, 0)), 0).rg;\n    let b  = textureLoad(field, vec2<i32>(p.x, min(p.y + 1, dims.y - 1)), 0).rg;\n    let tl = textureLoad(field, vec2<i32>(max(p.x - 1, 0), max(p.y - 1, 0)), 0).rg;\n    let tr = textureLoad(field, vec2<i32>(min(p.x + 1, dims.x - 1), max(p.y - 1, 0)), 0).rg;\n    let bl = textureLoad(field, vec2<i32>(max(p.x - 1, 0), min(p.y + 1, dims.y - 1)), 0).rg;\n    let br = textureLoad(field, vec2<i32>(min(p.x + 1, dims.x - 1), min(p.y + 1, dims.y - 1)), 0).rg;\n    let lap = -c + 0.2 * (l + r + t + b) + 0.05 * (tl + tr + bl + br);\n    let uvv = c.x * c.y * c.y;\n    let du = u.diff_u * lap.x - uvv + u.feed * (1.0 - c.x);\n    let dv = u.diff_v * lap.y + uvv - (u.feed + u.kill) * c.y;\n    let nu = clamp(c.x + du * u.dt, 0.0, 1.0);\n    let nv = clamp(c.y + dv * u.dt, 0.0, 1.0);\n    textureStore(output_tex, p, vec4<f32>(nu, nv, 0.0, 1.0));\n}\n"
