{
  "version": 2,
  "name": "TwistColumn",
  "description": "MESH_DEFORM_AND_CURVE_GEOMETRY_DESIGN P2 demo. A flat grid strip, long in X (node.grid_mesh -> node.make_triangles for smooth finite-difference normals), twists about its own X length (node.twist_mesh) into a helix. angle is driven by a Free-mode Saw LFO (min=0, max=3*pi) so it ramps continuously past 2*pi with no wrap seam — the performer gesture of a saw LFO doing full revolutions (BUG-039 class, angle is unbounded). node.mesh_ramp grows the twist along X so the column reads as more twisted at one end than the other.",
  "presetMetadata": {
    "id": "TwistColumn",
    "displayName": "Twist Column",
    "category": "Geometry",
    "oscPrefix": "twistcolumn",
    "available": true,
    "isLineBased": false,
    "params": [
      {
        "id": "speed",
        "name": "Speed",
        "min": 0.0,
        "max": 5.0,
        "defaultValue": 1.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      },
      {
        "id": "growth",
        "name": "Growth",
        "min": -1.0,
        "max": 2.0,
        "defaultValue": 0.0,
        "wholeNumbers": false,
        "isToggle": false,
        "isTrigger": false,
        "formatString": "F2"
      }
    ],
    "bindings": [
      {
        "id": "speed",
        "label": "Speed",
        "defaultValue": 1.0,
        "target": {
          "kind": "node",
          "nodeId": "twist_lfo",
          "param": "angular_rate"
        },
        "convert": {
          "type": "Float"
        }
      },
      {
        "id": "growth",
        "label": "Growth",
        "defaultValue": 0.0,
