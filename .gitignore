target/
*.manifold
**/.DS_Store
# Worktree-pool lease (scripts/agent-worktree.py) — session-local claim marker,
# lives at each worktree's root; mtime is the staleness clock.
.worktree-lease.json
# Runtime diagnostic logs from MANIFOLD_LOG_CHAIN_STATS etc.
chain-stats.log
*.log
.codex/tmp/
.codex/scratch/
.codex/*.local.md
assets/mri-data/
profiling_sessions/
__pycache__/
.venv/
# .claude is versioned selectively: hooks + daemon + settings are the model-steering
# layer and must have history; local state stays ignored.
.claude/*
!.claude/hooks/
!.claude/daemon/
!.claude/settings.json
!.claude/GIT_TREE_DISCIPLINE.md
.claude/settings.local.json
.claude/daemon/verdicts/
.claude/daemon/telemetry.jsonl
.claude/daemon/eval/run*.json
.claude/daemon/eval/fires*.json
.claude/daemon/eval/verdict_cache.jsonl
# Per-fire transcript slices cut by slice_fires.py for sleep-pass grading —
# transcript content, regenerable, never committed.
.claude/daemon/eval/slices/
# Provisional per-session self-grades (grader:session). Sessions append here so
# the tracked live_grades.jsonl (the durable, pass-graded corpus) never goes
# dirty mid-session and never blocks an orchestration landing. The sleep pass
# reads these, confirms/overrides against transcripts, folds verdicts into
# live_grades.jsonl, then clears them (RUNBOOK steps 2 + 8).
.claude/daemon/eval/live_grades.session*.jsonl
# Retrospective end-of-session review findings (miss-candidates, notes) —
# never a second grade line for an already-graded fire. Same lifecycle as
# the session grade files above: sleep pass folds them in, then clears them
# (RUNBOOK steps 2/3 + 8).
.claude/daemon/eval/observations.session.jsonl

# Real-audio eval fixtures for the mod_harness (copyrighted clips — never commit)
tests/fixtures/audio/

# Khronos glTF-Sample-Assets conformance fixtures (GLB_CONFORMANCE_DESIGN.md
# D1) — fetched by scripts/fetch-gltf-conformance.sh from a pinned commit,
# never vendored (mixed licenses, hundreds of MB across the full suite).
# manifest.json itself (the pin + per-asset checks) stays tracked.
tests/fixtures/gltf/khronos/*
!tests/fixtures/gltf/khronos/manifest.json
