/target
*.manifold
**/.DS_Store
# Runtime diagnostic logs from MANIFOLD_LOG_CHAIN_STATS etc.
chain-stats.log
*.log
.codex/tmp/
.codex/scratch/
.codex/*.local.md
assets/mri-data/
profiling_sessions/
__pycache__/
.venv/
# .claude is versioned selectively: hooks + substrate + settings are the model-steering
# layer and must have history; local state stays ignored.
.claude/*
!.claude/hooks/
!.claude/substrate/
!.claude/settings.json
.claude/settings.local.json
.claude/substrate/verdicts/
.claude/substrate/telemetry.jsonl
