target/
*.manifold
**/.DS_Store
# Runtime diagnostic logs from MANIFOLD_LOG_CHAIN_STATS etc.
chain-stats.log
*.log
.codex/tmp/
.codex/scratch/
.codex/*.local.md
assets/mri-data/
profiling_sessions/
__pycache__/
.venv/
# .claude is versioned selectively: hooks + daemon + settings are the model-steering
# layer and must have history; local state stays ignored.
.claude/*
!.claude/hooks/
!.claude/daemon/
!.claude/settings.json
!.claude/GIT_TREE_DISCIPLINE.md
.claude/settings.local.json
.claude/daemon/verdicts/
.claude/daemon/telemetry.jsonl
.claude/daemon/eval/run*.json
.claude/daemon/eval/fires*.json
.claude/daemon/eval/verdict_cache.jsonl
